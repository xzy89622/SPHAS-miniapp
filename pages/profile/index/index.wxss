.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f4f7fb 0%, #f7f8fc 100%);
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, .05);
  padding: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.7;
}

.entry-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #f8fbff 100%);
  border: 1rpx solid #dbeafe;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.entry-left {
  flex: 1;
}

.entry-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2563eb;
}

.entry-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.entry-arrow {
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #2563eb;
  font-weight: 700;
}

.form-item {
  margin-top: 24rpx;
}

.label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 600;
}

.input {
  height: 84rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #111827;
  display: flex;
  align-items: center;
}

.input-disabled {
  color: #94a3b8;
}

.gender-row {
  display: flex;
  gap: 18rpx;
}

.gender-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  font-size: 28rpx;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.gender-btn-active {
  background: #eef4ff;
  border: 1rpx solid #3b82f6;
  color: #2563eb;
  font-weight: 700;
}

.save-btn {
  margin-top: 36rpx;
  height: 84rpx;
  border-radius: 20rpx;
  border: none;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  padding: 0;
}

.save-btn::after {
  border: none;
}