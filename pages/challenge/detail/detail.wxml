<view class="page">
  <view wx:if="{{loading}}" class="state-card">加载中...</view>
  <view wx:if="{{errMsg}}" class="state-card err">{{errMsg}}</view>

  <block wx:if="{{!loading && detail}}">
    <view class="hero-card">
      <view class="hero-top">
        <view class="type-tag">{{detail.typeText}}</view>
        <view class="reward-tag">+{{detail.rewardPoints}} 积分</view>
      </view>

      <view class="hero-title">{{detail.title}}</view>
      <view class="hero-desc">{{detail.description}}</view>
    </view>

    <view class="card">
      <view class="section-title">挑战信息</view>

      <view class="info-row">
        <view class="info-label">目标值</view>
        <view class="info-value">{{detail.targetValue}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">开始日期</view>
        <view class="info-value">{{detail.startDateText}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">结束日期</view>
        <view class="info-value">{{detail.endDateText}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">我的状态</view>

      <view class="info-row">
        <view class="info-label">参与状态</view>
        <view class="info-value">{{joinedText}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">完成状态</view>
        <view class="info-value">{{finishedText}}</view>
      </view>
      <view class="info-row">
        <view class="info-label">当前进度</view>
        <view class="info-value">{{progressValue}} / {{detail.targetValue}}</view>
      </view>

      <view class="progress-wrap">
        <view class="progress-bar">
          <view class="progress-inner" style="{{progressBarStyle}}"></view>
        </view>
        <view class="progress-text">完成度 {{progressPercent}}%</view>
      </view>

      <view wx:if="{{showMyProgressRank}}" class="rank-tip">
        我的进度排名：第 {{myProgressRank.rank}} 名
      </view>

      <view wx:if="{{showMyFinishRank}}" class="rank-tip">
        我的完成排名：第 {{myFinishRank.rank}} 名
      </view>

      <button wx:if="{{!joined}}" class="main-btn" type="primary" bindtap="joinNow">报名挑战</button>

      <view wx:if="{{joined && !finished}}" class="action-box">
        <input
          class="ipt"
          type="number"
          placeholder="请输入新的进度值"
          value="{{progressInput}}"
          bindinput="onProgressInput"
        />
        <view class="btn-row">
          <button size="mini" class="ghost-btn" bindtap="fillTarget">填入目标值</button>
          <button size="mini" class="mini-main-btn" type="primary" bindtap="saveProgress">更新进度</button>
        </view>
      </view>

      <button wx:if="{{joined && !finished}}" class="finish-btn" bindtap="finishNow">
        完成挑战
      </button>
    </view>

    <view wx:if="{{progressRankList.length > 0}}" class="card">
      <view class="section-title">进度排行榜</view>
      <block wx:for="{{progressRankList}}" wx:key="index">
        <view class="rank-item">
          <view class="rank-left">
            <view class="rank-no">#{{item.rankText}}</view>
            <view class="rank-user">{{item.userText}}</view>
          </view>
          <view class="rank-score">{{item.scoreText}}</view>
        </view>
      </block>
    </view>

    <view wx:if="{{finishRankList.length > 0}}" class="card">
      <view class="section-title">完成排行榜</view>
      <block wx:for="{{finishRankList}}" wx:key="index">
        <view class="rank-item">
          <view class="rank-left">
            <view class="rank-no">#{{item.rankText}}</view>
            <view class="rank-user">{{item.userText}}</view>
          </view>
          <view class="rank-score">{{item.scoreText}}</view>
        </view>
      </block>
    </view>
  </block>
</view>