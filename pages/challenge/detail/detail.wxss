.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fb 0%, #eef6f2 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.state-card {
  margin-top: 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 44rpx 24rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.state-card.err {
  color: #ef4444;
}

.hero-card,
.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 26rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #16a34a;
  font-size: 22rpx;
  font-weight: 700;
}

.reward-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.45;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.8;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 18rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #94a3b8;
}

.info-value {
  font-size: 26rpx;
  color: #334155;
  font-weight: 700;
  text-align: right;
}

.progress-wrap {
  margin-top: 20rpx;
}

.progress-bar {
  width: 100%;
  height: 22rpx;
  background: #edf2f7;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
}

.progress-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.rank-tip {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #334155;
  font-size: 24rpx;
  line-height: 1.7;
}

.main-btn,
.finish-btn {
  margin-top: 22rpx;
  border-radius: 20rpx;
}

.action-box {
  margin-top: 22rpx;
}

.ipt {
  width: 100%;
  height: 82rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #334155;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.ghost-btn {
  background: #f3f4f6;
  color: #334155;
}

.mini-main-btn {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  color: #ffffff;
}

.rank-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-left {
  display: flex;
  align-items: center;
}

.rank-no {
  width: 92rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #334155;
}

.rank-user {
  font-size: 27rpx;
  color: #111827;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 800;
  color: #16a34a;
}