.page {
  padding: 24rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 18rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #666;
}

.tab.active {
  color: #111;
  font-weight: 700;
  border-bottom: 4rpx solid #16c15d;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.desc {
  color: #555;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.line {
  color: #666;
  margin-top: 6rpx;
  font-size: 26rpx;
}

.status {
  text-align: center;
  padding: 50rpx 0;
  color: #888;
}

.err {
  color: #d93025;
}