<view class="page">
  <view class="hero card">
    <view class="hero-title">健康风险预警</view>
    <view class="hero-desc">
      基于最新体质指标、生活方式和趋势变化，生成风险等级、干预建议和未来趋势预测。
    </view>

    <view class="hero-actions">
      <button class="primary-btn" loading="{{evaluating}}" bindtap="doEvaluate">
        {{evaluating ? '生成中...' : '立即生成预警'}}
      </button>
      <button class="ghost-btn" bindtap="goRecord">去录入体质数据</button>
    </view>
  </view>

  <view class="tabs card">
    <view class="tab-title">统计周期</view>
    <view class="tab-row">
      <view class="tab {{days===7 ? 'active' : ''}}" data-days="7" bindtap="changeDays">近7天</view>
      <view class="tab {{days===30 ? 'active' : ''}}" data-days="30" bindtap="changeDays">近30天</view>
      <view class="tab {{days===90 ? 'active' : ''}}" data-days="90" bindtap="changeDays">近90天</view>
    </view>
  </view>

  <view class="stats">
    <view class="stat-card">
      <view class="stat-label">预警总数</view>
      <view class="stat-value">{{dashboard.total}}</view>
    </view>

    <view class="stat-card safe">
      <view class="stat-label">低风险</view>
      <view class="stat-value">{{dashboard.levelCounts.LOW}}</view>
    </view>

    <view class="stat-card warn">
      <view class="stat-label">中风险</view>
      <view class="stat-value">{{dashboard.levelCounts.MID}}</view>
    </view>

    <view class="stat-card danger">
      <view class="stat-label">高风险</view>
      <view class="stat-value">{{dashboard.levelCounts.HIGH}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">风险趋势图</view>
    <view class="chart-desc">点击或左右滑动图表，可查看每天的预警次数</view>

    <view class="chart-wrap">
      <canvas
        canvas-id="riskTrendCanvas"
        id="riskTrendCanvas"
        class="trend-canvas"
        style="width: {{chartWidth}}px; height: {{chartHeight}}px;"
        bindtap="onChartTap"
        bindtouchstart="onChartTouchStart"
        bindtouchmove="onChartTouchMove"
        bindtouchend="onChartTouchEnd"
      ></canvas>

      <view
        wx:if="{{chartHintVisible}}"
        class="chart-tooltip"
        style="left: {{chartHintLeft}}px; top: {{chartHintTop}}px;"
      >
        <view class="chart-tooltip-date">{{activeChartLabel}}</view>
        <view class="chart-tooltip-value">预警次数：{{activeChartValue}}</view>
      </view>
    </view>

    <view class="chart-tip-row" wx:if="{{chartHintVisible}}">
      <view class="chart-tip-text">当前查看：{{activeChartLabel}}，预警次数 {{activeChartValue}}</view>
      <view class="chart-tip-close" bindtap="hideChartHint">收起</view>
    </view>
  </view>

  <view class="card" wx:if="{{dashboard.aiConclusion}}">
    <view class="section-title">AI 风险总结</view>
    <view class="summary">{{dashboard.aiConclusion}}</view>
    <view class="sub-line" wx:if="{{dashboard.latestHighTime}}">
      最近一次高风险时间：{{dashboard.latestHighTime}}
    </view>
  </view>

  <view class="card" wx:if="{{latestResult}}">
    <view class="section-title">本次最新评估结果</view>

    <view class="result-top">
      <view class="level-badge {{latestResult.riskLevel === 'HIGH' ? 'danger' : (latestResult.riskLevel === 'MID' ? 'warn' : 'safe')}}">
        {{latestResult.riskLevelText}}
      </view>
      <view class="score">风险分：{{latestResult.riskScore}}</view>
    </view>

    <view class="block" wx:if="{{latestResult.reasons && latestResult.reasons.length}}">
      <view class="block-title">触发原因</view>
      <view class="tag-list">
        <view class="tag" wx:for="{{latestResult.reasons}}" wx:key="index">{{item}}</view>
      </view>
    </view>

    <view class="block" wx:if="{{latestResult.aiSummary}}">
      <view class="block-title">AI 解读</view>
      <view class="text">{{latestResult.aiSummary}}</view>
    </view>

    <view class="block" wx:if="{{latestResult.advice}}">
      <view class="block-title">干预建议</view>
      <view class="text">{{latestResult.advice}}</view>
    </view>

    <view class="block" wx:if="{{latestResult.aiPrediction}}">
      <view class="block-title">未来预测</view>

      <view class="predict-grid">
        <view class="predict-item">
          <view class="p-label">模型</view>
          <view class="p-value">{{latestResult.aiPrediction.model || '-'}}</view>
        </view>

        <view class="predict-item">
          <view class="p-label">预测天数</view>
          <view class="p-value">{{latestResult.aiPrediction.horizonDays || '-'}} 天</view>
        </view>

        <view class="predict-item">
          <view class="p-label">预测风险分</view>
          <view class="p-value">{{latestResult.aiPrediction.predictedRiskScore || '-'}}</view>
        </view>

        <view class="predict-item">
          <view class="p-label">预测等级</view>
          <view class="p-value">{{latestResult.aiPrediction.predictedLevelText || '-'}}</view>
        </view>

        <view class="predict-item">
          <view class="p-label">趋势</view>
          <view class="p-value">{{latestResult.aiPrediction.trendText || '-'}}</view>
        </view>

        <view class="predict-item" wx:if="{{latestResult.aiPrediction.predictedWeightKg}}">
          <view class="p-label">预测体重</view>
          <view class="p-value">{{latestResult.aiPrediction.predictedWeightKg}} kg</view>
        </view>

        <view class="predict-item">
          <view class="p-label">置信度</view>
          <view class="p-value">{{latestResult.aiPrediction.confidenceText || '-'}}</view>
        </view>

        <view class="predict-item">
          <view class="p-label">历史样本</view>
          <view class="p-value">{{latestResult.aiPrediction.historyCount || 0}} 条</view>
        </view>
      </view>

      <view class="predict-msg" wx:if="{{latestResult.aiPrediction.message}}">
        <view class="block-title small">预测结论</view>
        <view class="text">{{latestResult.aiPrediction.message}}</view>
      </view>

      <view class="predict-basis" wx:if="{{latestResult.aiPrediction.basis && latestResult.aiPrediction.basis.length}}">
        <view class="block-title small">预测依据</view>
        <view class="basis-list">
          <view class="basis-item" wx:for="{{latestResult.aiPrediction.basis}}" wx:key="index">
            <text class="basis-dot">•</text>
            <text class="basis-text">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="text" wx:if="{{latestResult.aiPrediction.suggestion}}">
        {{latestResult.aiPrediction.suggestion}}
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">历史预警记录</view>

    <view wx:if="{{!loading && historyList.length===0}}" class="empty">
      暂无历史预警记录，先点击“立即生成预警”
    </view>

    <view class="history-item" wx:for="{{historyList}}" wx:key="id" data-id="{{item.id}}" bindtap="goHistoryDetail">
      <view class="history-top">
        <view class="level-badge {{item.riskLevel === 'HIGH' ? 'danger' : (item.riskLevel === 'MID' ? 'warn' : 'safe')}}">
          {{item.riskLevelText}}
        </view>
        <view class="time">{{item.createTimeText}}</view>
      </view>

      <view class="history-score">风险分：{{item.riskScore}}</view>

      <view class="tag-list" wx:if="{{item.reasons && item.reasons.length}}">
        <view class="tag" wx:for="{{item.reasons}}" wx:key="index">{{item}}</view>
      </view>

      <view class="history-text ellipsis-2" wx:if="{{item.aiSummary}}">
        AI 解读：{{item.aiSummary}}
      </view>

      <view class="history-text ellipsis-2" wx:if="{{item.advice}}">
        建议：{{item.advice}}
      </view>

      <view class="history-more">
        <text>查看详情</text>
        <text class="more-arrow">></text>
      </view>
    </view>
  </view>

  <view class="bottom-actions">
    <button class="mini-btn" bindtap="goLatest">查看最近健康记录</button>
    <button class="mini-btn" bindtap="goRecord">去录入数据</button>
  </view>

  <view class="status" wx:if="{{loading}}">加载中...</view>
  <view class="status err" wx:if="{{!loading && errorMsg}}">{{errorMsg}}</view>
</view>