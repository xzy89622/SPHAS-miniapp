.page{
  min-height:100vh;
  padding:24rpx;
  box-sizing:border-box;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
}

.hero-card,
.report-card,
.status-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.hero-card{
  padding:28rpx;
  margin-bottom:20rpx;
}

.hero-title{
  font-size:38rpx;
  font-weight:700;
  color:#111827;
}

.hero-desc{
  margin-top:8rpx;
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.6;
}

.tab-row{
  margin-top:24rpx;
  display:flex;
  gap:16rpx;
}

.tab-item{
  flex:1;
  height:76rpx;
  border-radius:18rpx;
  background:#f1f5f9;
  color:#475569;
  font-size:28rpx;
  font-weight:600;
  display:flex;
  align-items:center;
  justify-content:center;
}

.tab-item-active{
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  color:#ffffff;
}

.report-card{
  padding:24rpx;
  margin-bottom:20rpx;
}

.card-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
}

.report-type{
  min-width:88rpx;
  height:48rpx;
  padding:0 16rpx;
  border-radius:24rpx;
  background:#eff6ff;
  color:#2563eb;
  font-size:24rpx;
  font-weight:600;
  display:flex;
  align-items:center;
  justify-content:center;
}

.report-time{
  font-size:22rpx;
  color:#94a3b8;
}

.report-title{
  margin-top:16rpx;
  font-size:31rpx;
  font-weight:700;
  color:#111827;
  line-height:1.5;
}

.report-range{
  margin-top:10rpx;
  font-size:25rpx;
  color:#64748b;
}

.report-summary{
  margin-top:14rpx;
  font-size:26rpx;
  color:#334155;
  line-height:1.7;
}

.status-card{
  padding:30rpx;
  text-align:center;
  margin-bottom:20rpx;
}

.error-card{
  background:#fff7f7;
}

.status-text{
  font-size:28rpx;
  color:#475569;
}

.bottom-tip{
  padding:24rpx 0 40rpx;
  text-align:center;
  font-size:24rpx;
  color:#94a3b8;
}