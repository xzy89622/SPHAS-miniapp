.page{
  min-height:100vh;
  padding:24rpx;
  box-sizing:border-box;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
}

.hero-card,
.card,
.status-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.hero-card{
  padding:28rpx;
  margin-bottom:20rpx;
}

.hero-tag{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:88rpx;
  height:48rpx;
  padding:0 16rpx;
  border-radius:24rpx;
  background:#eff6ff;
  color:#2563eb;
  font-size:24rpx;
  font-weight:600;
}

.hero-title{
  margin-top:16rpx;
  font-size:36rpx;
  font-weight:700;
  color:#111827;
  line-height:1.5;
}

.hero-range{
  margin-top:10rpx;
  font-size:26rpx;
  color:#475569;
}

.hero-time{
  margin-top:8rpx;
  font-size:24rpx;
  color:#94a3b8;
}

.card{
  padding:24rpx;
  margin-bottom:20rpx;
}

.card-title{
  font-size:32rpx;
  font-weight:700;
  color:#111827;
  line-height:1.4;
  margin-bottom:18rpx;
}

.summary-text{
  font-size:28rpx;
  color:#334155;
  line-height:1.7;
}

.metric-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16rpx;
}

.metric-item{
  padding:18rpx;
  border-radius:20rpx;
  background:#f8fafc;
  border:1rpx solid #edf2f7;
}

.metric-label{
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
}

.metric-value{
  margin-top:10rpx;
  font-size:30rpx;
  color:#1f2937;
  font-weight:700;
  line-height:1.4;
}

.tip-item{
  display:flex;
  align-items:flex-start;
  gap:14rpx;
  padding:14rpx 0;
  border-bottom:1rpx solid #f1f5f9;
}

.tip-item:last-child{
  border-bottom:none;
}

.tip-dot{
  width:14rpx;
  height:14rpx;
  border-radius:50%;
  background:#22c55e;
  margin-top:14rpx;
  flex-shrink:0;
}

.risk-dot{
  background:#ef4444;
}

.tip-text{
  flex:1;
  font-size:27rpx;
  color:#334155;
  line-height:1.7;
}

.status-card{
  padding:30rpx;
  text-align:center;
  margin-bottom:20rpx;
}

.error-card{
  background:#fff7f7;
}

.status-text{
  font-size:28rpx;
  color:#475569;
}

.empty-text{
  font-size:26rpx;
  color:#94a3b8;
}