.page{
  min-height:100vh;
  padding:24rpx;
  box-sizing:border-box;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
}

.hero-card,
.card,
.status-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.hero-card{
  padding:28rpx;
  margin-bottom:20rpx;
}

.hero-title{
  font-size:38rpx;
  font-weight:700;
  color:#111827;
  line-height:1.4;
}

.hero-desc{
  margin-top:8rpx;
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.6;
}

.tab-row{
  margin-top:24rpx;
  display:flex;
  gap:16rpx;
}

.tab-item{
  flex:1;
  height:76rpx;
  border-radius:18rpx;
  background:#f1f5f9;
  color:#475569;
  font-size:28rpx;
  font-weight:600;
  display:flex;
  align-items:center;
  justify-content:center;
}

.tab-item-active{
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  color:#ffffff;
}

.card{
  padding:24rpx;
  margin-bottom:20rpx;
}

.card-title{
  font-size:32rpx;
  font-weight:700;
  color:#111827;
  line-height:1.4;
  margin-bottom:18rpx;
}

.range-text{
  font-size:30rpx;
  color:#1f2937;
  font-weight:600;
  line-height:1.5;
}

.range-tip{
  margin-top:8rpx;
  font-size:24rpx;
  color:#94a3b8;
}

.metric-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16rpx;
}

.metric-item{
  padding:18rpx;
  border-radius:20rpx;
  background:#f8fafc;
  border:1rpx solid #edf2f7;
}

.metric-label{
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
}

.metric-value{
  margin-top:10rpx;
  font-size:30rpx;
  color:#1f2937;
  font-weight:700;
  line-height:1.4;
}

.summary-text{
  font-size:28rpx;
  color:#334155;
  line-height:1.7;
}

.tip-item{
  display:flex;
  align-items:flex-start;
  gap:14rpx;
  padding:14rpx 0;
  border-bottom:1rpx solid #f1f5f9;
}

.tip-item:last-child{
  border-bottom:none;
}

.tip-dot{
  width:14rpx;
  height:14rpx;
  border-radius:50%;
  background:#22c55e;
  margin-top:14rpx;
  flex-shrink:0;
}

.tip-text{
  flex:1;
  font-size:27rpx;
  color:#334155;
  line-height:1.7;
}

.status-card{
  padding:30rpx;
  text-align:center;
  margin-bottom:20rpx;
}

.error-card{
  background:#fff7f7;
}

.status-text{
  font-size:28rpx;
  color:#475569;
}

.empty-text{
  font-size:26rpx;
  color:#94a3b8;
}