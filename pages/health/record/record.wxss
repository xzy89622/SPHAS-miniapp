.page{
  min-height:100vh;
  padding:24rpx;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
  box-sizing:border-box;
}

.hero-card{
  background:linear-gradient(135deg,#ffffff 0%,#f7fbff 100%);
  border-radius:28rpx;
  padding:28rpx;
  box-shadow:0 10rpx 30rpx rgba(31,55,88,.06);
  margin-bottom:20rpx;
}

.hero-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:20rpx;
}

.hero-main{
  flex:1;
  min-width:0;
}

.hero-title{
  font-size:38rpx;
  line-height:1.3;
  font-weight:700;
  color:#1f2937;
}

.hero-desc{
  margin-top:10rpx;
  font-size:24rpx;
  line-height:1.6;
  color:#6b7280;
}

.hero-badge{
  flex-shrink:0;
  padding:12rpx 20rpx;
  background:#eef5ff;
  color:#2563eb;
  font-size:24rpx;
  border-radius:999rpx;
  font-weight:600;
}

.hero-stats{
  display:flex;
  gap:16rpx;
  margin-top:24rpx;
}

.stat-item{
  flex:1;
  background:#f8fafc;
  border-radius:20rpx;
  padding:18rpx 16rpx;
  min-width:0;
}

.stat-label{
  font-size:22rpx;
  color:#94a3b8;
  line-height:1.4;
}

.stat-value{
  margin-top:8rpx;
  font-size:28rpx;
  color:#1f2937;
  font-weight:700;
  line-height:1.4;
  word-break:break-all;
}

.section-card{
  background:#ffffff;
  border-radius:28rpx;
  padding:26rpx;
  box-shadow:0 8rpx 24rpx rgba(15,23,42,.05);
  margin-bottom:20rpx;
}

.section-head{
  margin-bottom:18rpx;
}

.section-title{
  font-size:30rpx;
  font-weight:700;
  color:#1f2937;
  line-height:1.4;
}

.section-tip{
  margin-top:6rpx;
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.5;
}

.field{
  margin-bottom:18rpx;
}

.field:last-child{
  margin-bottom:0;
}

.field-label{
  margin-bottom:12rpx;
  font-size:26rpx;
  color:#374151;
  font-weight:600;
  line-height:1.4;
  text-align:left;
}

.input{
  width:100%;
  height:88rpx;
  box-sizing:border-box;
  background:#f8fafc;
  border:1rpx solid #e8edf5;
  border-radius:18rpx;
  padding:0 22rpx;
  font-size:28rpx;
  color:#111827;
  line-height:88rpx;
  text-align:left;
  vertical-align:middle;
}

.picker{
  width:100%;
  min-height:88rpx;
  box-sizing:border-box;
  background:#f8fafc;
  border:1rpx solid #e8edf5;
  border-radius:18rpx;
  padding:20rpx 22rpx;
  font-size:28rpx;
  color:#111827;
  line-height:1.5;
  text-align:left;
  display:flex;
  align-items:center;
}

.textarea{
  width:100%;
  min-height:160rpx;
  box-sizing:border-box;
  background:#f8fafc;
  border:1rpx solid #e8edf5;
  border-radius:18rpx;
  padding:20rpx 22rpx;
  font-size:28rpx;
  color:#111827;
  line-height:1.5;
  text-align:left;
}

.input-placeholder{
  color:#9ca3af;
  line-height:88rpx;
}

.textarea-placeholder{
  color:#9ca3af;
  line-height:1.5;
}

.grid-2{
  display:flex;
  gap:16rpx;
}

.grid-item{
  flex:1;
  min-width:0;
}

.action-wrap{
  padding:12rpx 0 36rpx;
}

.action-bar{
  background:#ffffff;
  border-radius:28rpx;
  padding:24rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.action-note{
  margin-bottom:16rpx;
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.5;
  text-align:center;
}

.primary-btn,
.secondary-btn{
  width:100%;
  margin:0;
  padding:0;
  border:none;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  box-sizing:border-box;
}

.primary-btn{
  height:96rpx;
  min-height:96rpx;
  border-radius:24rpx;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 14rpx 28rpx rgba(37,99,235,.24);
}

.primary-btn::after{
  border:none;
}

.primary-btn[disabled]{
  opacity:.88;
}

.secondary-btn{
  height:88rpx;
  min-height:88rpx;
  margin-top:18rpx;
  border-radius:22rpx;
  background:#f8fafc;
  box-shadow:inset 0 0 0 1rpx #e5e7eb;
}

.secondary-btn::after{
  border:none;
}

.btn-text{
  display:block;
  width:100%;
  text-align:center;
  font-size:30rpx;
  line-height:1;
  font-weight:700;
  color:#ffffff;
}

.secondary-text{
  font-size:28rpx;
  color:#334155;
  font-weight:600;
}