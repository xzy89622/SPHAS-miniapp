.page{
  min-height:100vh;
  padding:24rpx;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
  box-sizing:border-box;
}

.hero-card{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20rpx;
  padding:28rpx;
  border-radius:28rpx;
  background:linear-gradient(135deg,#ffffff 0%,#f7fbff 100%);
  box-shadow:0 10rpx 30rpx rgba(31,55,88,.06);
  margin-bottom:20rpx;
}

.hero-main{
  flex:1;
  min-width:0;
}

.hero-title{
  font-size:42rpx;
  line-height:1.3;
  font-weight:700;
  color:#1f2937;
}

.hero-desc{
  margin-top:10rpx;
  font-size:24rpx;
  line-height:1.6;
  color:#6b7280;
}

.hero-side{
  flex-shrink:0;
  min-width:132rpx;
  padding:18rpx 16rpx;
  border-radius:22rpx;
  background:#eef5ff;
  text-align:center;
}

.hero-count{
  font-size:38rpx;
  line-height:1.2;
  font-weight:700;
  color:#2563eb;
}

.hero-count-label{
  margin-top:6rpx;
  font-size:22rpx;
  color:#5b8def;
}

.toolbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
  margin-bottom:18rpx;
}

.toolbar-left{
  flex:1;
  min-width:0;
}

.toolbar-title{
  font-size:30rpx;
  line-height:1.4;
  font-weight:700;
  color:#1f2937;
}

.toolbar-sub{
  margin-top:4rpx;
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.5;
}

.record-btn{
  min-width:220rpx;
  height:84rpx;
  margin:0;
  padding:0 28rpx;
  border:none;
  border-radius:22rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 12rpx 24rpx rgba(37,99,235,.22);
  box-sizing:border-box;
}

.record-btn::after{
  border:none;
}

.record-btn-text{
  font-size:30rpx;
  font-weight:700;
  color:#ffffff;
  line-height:1;
}

.list{
  display:flex;
  flex-direction:column;
  gap:18rpx;
}

.record-card{
  background:#ffffff;
  border-radius:28rpx;
  padding:24rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.card-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16rpx;
}

.card-date-block{
  flex:1;
  min-width:0;
}

.card-date{
  font-size:40rpx;
  line-height:1.25;
  font-weight:700;
  color:#111827;
}

.card-tip{
  margin-top:8rpx;
  font-size:22rpx;
  color:#94a3b8;
  line-height:1.4;
}

.weight-pill{
  flex-shrink:0;
  max-width:240rpx;
  padding:10rpx 18rpx;
  border-radius:999rpx;
  background:#eef5ff;
  color:#2563eb;
  font-size:26rpx;
  font-weight:700;
  line-height:1.3;
  text-align:center;
}

.metric-grid{
  display:flex;
  flex-wrap:wrap;
  gap:14rpx;
  margin-top:20rpx;
}

.metric-chip{
  display:flex;
  align-items:center;
  gap:10rpx;
  padding:12rpx 16rpx;
  background:#f8fafc;
  border:1rpx solid #edf2f7;
  border-radius:18rpx;
  min-height:68rpx;
  box-sizing:border-box;
}

.bmi-chip{
  background:linear-gradient(135deg,#f3f8ff 0%,#eef5ff 100%);
  border-color:#dbeafe;
}

.metric-label{
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.3;
}

.metric-value{
  font-size:28rpx;
  color:#334155;
  font-weight:600;
  line-height:1.3;
}

.metric-extra{
  font-size:22rpx;
  color:#2563eb;
  line-height:1.3;
  padding:4rpx 10rpx;
  background:rgba(37,99,235,.08);
  border-radius:999rpx;
}

.remark-box{
  margin-top:18rpx;
  padding:18rpx 20rpx;
  background:#f8fafc;
  border-radius:20rpx;
  border:1rpx solid #eef2f7;
}

.remark-label{
  font-size:22rpx;
  color:#94a3b8;
  line-height:1.4;
}

.remark-text{
  margin-top:8rpx;
  font-size:27rpx;
  color:#475569;
  line-height:1.6;
  word-break:break-all;
}

.card-footer{
  margin-top:18rpx;
  padding-top:18rpx;
  border-top:1rpx solid #f1f5f9;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.footer-text{
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.4;
}

.footer-arrow{
  font-size:34rpx;
  line-height:1;
  color:#c0cad8;
}

.state-card{
  margin-top:28rpx;
  padding:44rpx 32rpx;
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
  text-align:center;
}

.state-icon{
  font-size:54rpx;
  line-height:1;
}

.state-title{
  margin-top:18rpx;
  font-size:32rpx;
  font-weight:700;
  color:#1f2937;
  line-height:1.4;
}

.state-desc{
  margin-top:10rpx;
  font-size:25rpx;
  color:#94a3b8;
  line-height:1.6;
}

.empty-btn{
  width:100%;
  height:88rpx;
  margin-top:24rpx;
  padding:0;
  border:none;
  border-radius:22rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 12rpx 24rpx rgba(37,99,235,.20);
}

.empty-btn::after{
  border:none;
}

.empty-btn-text{
  font-size:30rpx;
  font-weight:700;
  color:#ffffff;
  line-height:1;
}