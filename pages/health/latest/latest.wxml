<view class="page">
  <view class="hero-card">
    <view class="hero-main">
      <view class="hero-title">最近健康记录</view>
      <view class="hero-desc">查看近几次录入情况，点击卡片可继续编辑当天数据</view>
    </view>

    <view class="hero-side">
      <view class="hero-count">{{list.length}}</view>
      <view class="hero-count-label">最近记录</view>
    </view>
  </view>

  <view class="toolbar">
    <view class="toolbar-left">
      <view class="toolbar-title">记录列表</view>
      <view class="toolbar-sub">近 7 条健康数据</view>
    </view>

    <button class="record-btn" bindtap="goRecord">
      <text class="record-btn-text">去录入</text>
    </button>
  </view>

  <view wx:if="{{loading}}" class="state-card">
    <view class="state-icon">⏳</view>
    <view class="state-title">正在加载记录</view>
    <view class="state-desc">请稍候，马上为你展示最近健康数据</view>
  </view>

  <view wx:if="{{!loading && list.length===0}}" class="state-card empty">
    <view class="state-icon">🩺</view>
    <view class="state-title">还没有健康记录</view>
    <view class="state-desc">先录入一条数据，后续才能进行趋势分析和推荐</view>
    <button class="empty-btn" bindtap="goRecord">
      <text class="empty-btn-text">立即录入</text>
    </button>
  </view>

  <view wx:if="{{!loading && list.length>0}}" class="list">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="record-card"
      bindtap="edit"
      data-date="{{item.recordDate}}"
    >
      <view class="card-top">
        <view class="card-date-block">
          <view class="card-date">{{item.recordDate}}</view>
          <view class="card-tip">点击可编辑当天记录</view>
        </view>

        <view class="weight-pill" wx:if="{{item.weightKg}}">
          体重 {{item.weightKg}}kg
        </view>
      </view>

      <view class="metric-grid">
        <view class="metric-chip" wx:if="{{item.heightCm}}">
          <text class="metric-label">身高</text>
          <text class="metric-value">{{item.heightCm}}cm</text>
        </view>

        <view class="metric-chip bmi-chip" wx:if="{{item.bmiText}}">
          <text class="metric-label">BMI</text>
          <text class="metric-value">{{item.bmiText}}</text>
          <text class="metric-extra">{{item.bmiLevel}}</text>
        </view>

        <view class="metric-chip" wx:if="{{item.systolic && item.diastolic}}">
          <text class="metric-label">血压</text>
          <text class="metric-value">{{item.systolic}}/{{item.diastolic}}</text>
        </view>

        <view class="metric-chip" wx:if="{{item.heartRate}}">
          <text class="metric-label">心率</text>
          <text class="metric-value">{{item.heartRate}}</text>
        </view>

        <view class="metric-chip" wx:if="{{item.steps}}">
          <text class="metric-label">步数</text>
          <text class="metric-value">{{item.steps}}</text>
        </view>

        <view class="metric-chip" wx:if="{{item.sleepHours}}">
          <text class="metric-label">睡眠</text>
          <text class="metric-value">{{item.sleepHours}}h</text>
        </view>
      </view>

      <view class="remark-box" wx:if="{{item.remark}}">
        <view class="remark-label">备注</view>
        <view class="remark-text">{{item.remark}}</view>
      </view>

      <view class="card-footer">
        <view class="footer-text">继续完善这一天的数据</view>
        <view class="footer-arrow">›</view>
      </view>
    </view>
  </view>
</view>