.page{
  min-height:100vh;
  padding:24rpx;
  box-sizing:border-box;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
}

.hero-card,
.feedback-card,
.empty-card,
.footer-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.hero-card{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:18rpx;
  padding:28rpx;
  margin-bottom:20rpx;
  background:linear-gradient(135deg,#ffffff 0%,#f7fbff 100%);
}

.hero-main{
  flex:1;
  min-width:0;
}

.hero-title{
  font-size:42rpx;
  line-height:1.3;
  color:#111827;
  font-weight:700;
}

.hero-desc{
  margin-top:10rpx;
  font-size:25rpx;
  line-height:1.6;
  color:#6b7280;
}

.create-btn{
  flex-shrink:0;
  min-width:176rpx;
  height:78rpx;
  margin:0;
  padding:0 24rpx;
  border:none;
  border-radius:20rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 10rpx 22rpx rgba(37,99,235,.20);
}

.create-btn::after{
  border:none;
}

.create-btn-text{
  font-size:28rpx;
  line-height:1;
  color:#ffffff;
  font-weight:700;
}

.summary-row{
  display:flex;
  gap:16rpx;
  margin-bottom:20rpx;
}

.summary-item{
  flex:1;
  min-width:0;
  background:#ffffff;
  border-radius:24rpx;
  padding:20rpx 18rpx;
  box-shadow:0 8rpx 24rpx rgba(15,23,42,.05);
}

.summary-label{
  font-size:22rpx;
  color:#94a3b8;
  line-height:1.4;
}

.summary-value{
  margin-top:10rpx;
  font-size:34rpx;
  line-height:1.2;
  color:#111827;
  font-weight:700;
}

.summary-value.pending{
  color:#d97706;
}

.summary-value.done{
  color:#16a34a;
}

.feedback-list{
  display:flex;
  flex-direction:column;
  gap:18rpx;
}

.feedback-card{
  padding:24rpx;
}

.card-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:18rpx;
}

.title-wrap{
  flex:1;
  min-width:0;
}

.feedback-title{
  font-size:38rpx;
  line-height:1.4;
  color:#111827;
  font-weight:700;
  word-break:break-all;
}

.feedback-time{
  margin-top:10rpx;
  font-size:24rpx;
  line-height:1.5;
  color:#94a3b8;
}

.status-badge{
  flex-shrink:0;
  padding:10rpx 18rpx;
  border-radius:999rpx;
  font-size:24rpx;
  line-height:1.2;
  font-weight:700;
}

.status-badge.pending{
  background:#fffbeb;
  color:#d97706;
}

.status-badge.done{
  background:#f0fdf4;
  color:#16a34a;
}

.status-badge.reject{
  background:#fef2f2;
  color:#dc2626;
}

.feedback-content{
  margin-top:16rpx;
  font-size:27rpx;
  line-height:1.75;
  color:#64748b;
  word-break:break-all;
}

.progress-wrap{
  margin-top:18rpx;
}

.progress-track{
  width:100%;
  height:16rpx;
  border-radius:999rpx;
  background:#eef2f7;
  overflow:hidden;
}

.progress-fill{
  height:100%;
  border-radius:999rpx;
}

.progress-fill.pending{
  background:linear-gradient(90deg,#f59e0b 0%,#fbbf24 100%);
}

.progress-fill.done{
  background:linear-gradient(90deg,#22c55e 0%,#16a34a 100%);
}

.progress-fill.reject{
  background:linear-gradient(90deg,#ef4444 0%,#dc2626 100%);
}

.progress-text{
  margin-top:10rpx;
  font-size:23rpx;
  line-height:1.4;
  color:#94a3b8;
}

.card-bottom{
  margin-top:18rpx;
  padding-top:18rpx;
  border-top:1rpx solid #f1f5f9;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.feedback-type{
  font-size:24rpx;
  color:#64748b;
  line-height:1.4;
}

.card-arrow{
  font-size:34rpx;
  line-height:1;
  color:#c0cad8;
}

.empty-card{
  margin-top:40rpx;
  padding:56rpx 32rpx;
  text-align:center;
}

.empty-icon{
  font-size:56rpx;
  line-height:1;
}

.empty-title{
  margin-top:20rpx;
  font-size:32rpx;
  line-height:1.4;
  color:#1f2937;
  font-weight:700;
}

.empty-desc{
  margin-top:10rpx;
  font-size:25rpx;
  line-height:1.6;
  color:#94a3b8;
}

.empty-btn{
  width:100%;
  height:88rpx;
  margin-top:24rpx;
  padding:0;
  border:none;
  border-radius:22rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 12rpx 24rpx rgba(37,99,235,.20);
}

.empty-btn::after{
  border:none;
}

.empty-btn-text{
  font-size:30rpx;
  line-height:1;
  color:#ffffff;
  font-weight:700;
}

.footer-card{
  margin-top:18rpx;
  padding:22rpx 20rpx 34rpx;
  text-align:center;
}

.footer-text{
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.5;
}