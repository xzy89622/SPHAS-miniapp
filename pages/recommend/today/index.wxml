<view class="page">
  <view class="card">
    <view class="title">今日推荐</view>
    <view class="tip">根据你的评估结果推荐内容</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 非加载中 -->
  <block wx:else>
    <!-- 有错误 -->
    <view wx:if="{{errMsg}}" class="error">
      {{errMsg}}
      <button size="mini" bindtap="loadToday">重试</button>
    </view>

    <!-- 无错误但空 -->
    <view wx:elif="{{items.length === 0}}" class="empty">
      暂无推荐内容
      <view class="empty-tip">（你可以先完成一次体质评估，再回来看看）</view>
      <button size="mini" bindtap="loadToday">刷新</button>
    </view>

    <!-- 有数据 -->
    <block wx:else>
      <block wx:for="{{items}}" wx:for-item="it" wx:key="id">
        <view class="item">
          <view class="item-title">{{it.title || it.name || it.type || '推荐'}}</view>
          <view class="item-desc">{{it.content || it.desc || it.description || it.advice || ''}}</view>
        </view>
      </block>
    </block>
  </block>
</view>