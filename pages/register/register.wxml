<view class="register-page">
  <view class="bg bg-1"></view>
  <view class="bg bg-2"></view>

  <view class="register-wrapper">
    <view class="brand-box">
      <view class="brand-badge">S</view>
      <view class="brand-text">
        <view class="brand-title">SPHAS 健康助手</view>
        <view class="brand-subtitle">通过手机号快速创建账号并开始健康记录</view>
      </view>
    </view>

    <view class="register-card">
      <view class="card-title">手机号注册</view>
      <view class="card-desc">注册成功后将自动登录，你可以继续完善个人健康信息</view>

      <view class="form-item">
        <view class="label">手机号 <text class="required">*</text></view>
        <view class="input-wrap">
          <input
            class="input"
            type="number"
            maxlength="11"
            placeholder="请输入 11 位手机号"
            placeholder-class="ph"
            value="{{form.phone}}"
            bindinput="onPhone"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="label">昵称</view>
        <view class="input-wrap">
          <input
            class="input"
            placeholder="请输入昵称（可选）"
            placeholder-class="ph"
            value="{{form.nickname}}"
            bindinput="onNickname"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="label">密码 <text class="required">*</text></view>
        <view class="input-wrap">
          <input
            class="input"
            password
            placeholder="请输入密码（至少 6 位）"
            placeholder-class="ph"
            value="{{form.password}}"
            bindinput="onPassword"
          />
        </view>
      </view>

      <view class="form-item">
        <view class="label">确认密码 <text class="required">*</text></view>
        <view class="input-wrap">
          <input
            class="input"
            password
            placeholder="请再次输入密码"
            placeholder-class="ph"
            value="{{form.confirmPassword}}"
            bindinput="onPassword2"
          />
        </view>
      </view>

      <button
        class="submit-btn"
        loading="{{submitting}}"
        disabled="{{submitting}}"
        bindtap="onRegister"
      >
        <text class="btn-text">{{submitting ? '注册中...' : '注册并登录'}}</text>
      </button>

      <view class="bottom-row">
        <text class="bottom-text">已有账号？</text>
        <text class="login-link" bindtap="goLogin">返回登录</text>
      </view>
    </view>
  </view>
</view>