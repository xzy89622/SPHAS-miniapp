<view class="page">
  <view class="header">
    <view class="title">健康社区</view>
    <button size="mini" type="primary" bindtap="goPublish">发日志</button>
  </view>

  <view wx:if="{{loading}}" class="status">加载中...</view>
  <view wx:if="{{!loading && errMsg}}" class="status err">{{errMsg}}</view>

  <view wx:if="{{!loading && posts.length === 0 && !errMsg}}" class="status">
    暂无内容（发一条日志试试～）
  </view>

  <block wx:for="{{posts}}" wx:key="id">
    <view class="card" bindtap="goDetail" data-id="{{item.id}}">
      <view class="content">{{item.content}}</view>

      <view wx:if="{{item._images.length > 0}}" class="imgs">
        <image
          wx:for="{{item._images}}"
          wx:for-item="img"
          wx:key="*this"
          class="img"
          src="{{img}}"
          mode="aspectFill"
          data-src="{{img}}"
          bindtap="previewImg"
        />
      </view>

      <view class="meta">
        <text>👍 {{item.likeCount || 0}}</text>
        <text>💬 {{item.commentCount || 0}}</text>
        <text class="time">{{item.showTime}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{hasMore && !loading && posts.length > 0}}" class="more" bindtap="loadMore">
    加载更多
  </view>
  <view wx:if="{{!hasMore && posts.length > 0}}" class="more">没有更多了</view>
</view>