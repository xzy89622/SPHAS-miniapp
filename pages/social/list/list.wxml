<view class="page">
  <view class="hero-card">
    <view class="hero-left">
      <view class="hero-title">健康社区</view>
      <view class="hero-sub">看看大家最近的健康打卡和生活分享</view>
    </view>

    <view class="hero-actions">
      <button class="ghost-btn" bindtap="goMine">我的帖子</button>
      <button class="primary-btn" bindtap="goPublish">发帖子</button>
    </view>
  </view>

  <view wx:if="{{loading && posts.length === 0}}" class="state-card">加载中...</view>
  <view wx:if="{{errMsg}}" class="state-card err">{{errMsg}}</view>
  <view wx:if="{{!loading && posts.length === 0 && !errMsg}}" class="state-card">社区里还没有内容，去发布第一条吧</view>

  <block wx:for="{{posts}}" wx:key="id">
    <view class="post-card" bindtap="goDetail" data-id="{{item.id}}">
      <view class="post-head">
        <view class="user-box">
          <view class="avatar">{{item.avatarText}}</view>
          <view class="user-meta">
            <view class="nickname">{{item.nicknameText}}</view>
            <view class="time-text">{{item.timeText}}</view>
          </view>
        </view>

        <view class="status-tag {{item.statusClass}}">{{item.statusText}}</view>
      </view>

      <view class="post-content">{{item.contentText}}</view>

      <view wx:if="{{item.hasImages}}" class="image-grid">
        <block wx:for="{{item.imageList}}" wx:key="index">
          <image
            class="grid-img"
            src="{{item}}"
            mode="aspectFill"
            bindtap="previewImg"
            catchtap="previewImg"
            data-src="{{item}}"
            data-urls="{{item.imageList}}"
          />
        </block>
      </view>

      <view class="meta-row">
        <view class="meta-item">👍 {{item.likeText}}</view>
        <view class="meta-item">💬 {{item.commentText}}</view>
      </view>
    </view>
  </block>

  <view wx:if="{{hasMore && posts.length > 0 && !loading}}" class="more" bindtap="loadMore">加载更多</view>
  <view wx:if="{{loading && posts.length > 0}}" class="more">加载中...</view>
  <view wx:if="{{!hasMore && posts.length > 0}}" class="more">没有更多了</view>
</view>