.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fb 0%, #eef6f2 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 26rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f3fbf6 100%);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.hero-left {
  flex: 1;
  padding-right: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.2;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #64748b;
  line-height: 1.6;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ghost-btn,
.publish-btn {
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost-btn {
  background: #edf2f7;
  color: #334155;
}

.publish-btn {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.16);
}

.state-wrap {
  margin-top: 30rpx;
}

.state-card {
  text-align: center;
  padding: 44rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #94a3b8;
  font-size: 28rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.state-card.err {
  color: #ef4444;
}

.post-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 26rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.post-head {
  display: flex;
  align-items: center;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(34, 197, 94, 0.25);
  margin-right: 18rpx;
  flex-shrink: 0;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
}

.nickname {
  max-width: 360rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  margin-left: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #16a34a;
  font-size: 20rpx;
  font-weight: 700;
}

.time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.post-content {
  margin-top: 20rpx;
  font-size: 29rpx;
  color: #334155;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-all;
}

.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.grid-img {
  width: 206rpx;
  height: 206rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
}

.post-footer {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
}

.footer-item {
  display: flex;
  align-items: center;
  margin-right: 28rpx;
}

.footer-icon {
  font-size: 25rpx;
}

.footer-text {
  margin-left: 8rpx;
  font-size: 25rpx;
  color: #64748b;
}

.footer-link {
  margin-left: auto;
  font-size: 24rpx;
  color: #16a34a;
  font-weight: 700;
}

.more {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  padding: 22rpx 0 40rpx;
}