.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f7fb;
  box-sizing: border-box;
}

button::after {
  border: none;
}

.hero-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff, #f4f8ff);
  box-shadow: 0 10rpx 30rpx rgba(31, 75, 160, 0.08);
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
}

.primary-btn,
.ghost-btn {
  min-width: 180rpx;
  height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1;
  white-space: nowrap;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #4f7cff, #6a8dff);
  border: none;
}

.ghost-btn {
  color: #4f7cff;
  background: #eef4ff;
  border: 1rpx solid #d9e7ff;
}

.state-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #6b7280;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.state-card.err {
  color: #d14343;
  background: #fff5f5;
}

.post-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.05);
}

.post-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.user-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7aa5ff, #5e86ff);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-meta {
  min-width: 0;
}

.nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.time-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.status-tag.ok {
  color: #15803d;
  background: #eaf8ee;
}

.status-tag.pending {
  color: #b7791f;
  background: #fff7e6;
}

.status-tag.reject {
  color: #c53030;
  background: #fff1f1;
}

.status-tag.hidden {
  color: #6b7280;
  background: #f3f4f6;
}

.post-content {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  word-break: break-all;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.grid-img {
  width: 100%;
  height: 210rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.meta-row {
  display: flex;
  gap: 28rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-item {
  display: flex;
  align-items: center;
}

.more {
  padding: 24rpx 0 36rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}