.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f7fb;
  box-sizing: border-box;
}

button::after {
  border: none;
}

.card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.7;
}

.form-item {
  margin-top: 28rpx;
}

.label {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.textarea {
  width: 100%;
  min-height: 260rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  font-size: 28rpx;
  color: #374151;
  box-sizing: border-box;
}

.count {
  margin-top: 12rpx;
  text-align: right;
  font-size: 22rpx;
  color: #9ca3af;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.img-item,
.add-box {
  position: relative;
  width: 100%;
  height: 210rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.img {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  background: rgba(17, 24, 39, 0.55);
}

.add-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
}

.add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.add-text {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.7;
}

.submit-btn {
  margin-top: 34rpx;
  width: 100%;
  height: 82rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #4f7cff, #6a8dff);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}