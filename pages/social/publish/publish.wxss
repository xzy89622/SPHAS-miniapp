.page { padding: 24rpx; }
.card { background: #fff; border-radius: 18rpx; padding: 20rpx; margin-bottom: 16rpx; }
.ta { width: 100%; min-height: 160rpx; }
.count { text-align: right; color: #999; font-size: 24rpx; margin-top: 8rpx; }

.row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.label { font-weight: 600; }

.imgs { display: flex; flex-wrap: wrap; gap: 12rpx; }
.img-wrap { position: relative; }
.img { width: 210rpx; height: 210rpx; border-radius: 14rpx; }
.del {
  position: absolute; top: -10rpx; right: -10rpx;
  width: 36rpx; height: 36rpx; border-radius: 18rpx;
  background: rgba(0,0,0,0.6); color: #fff;
  display: flex; align-items: center; justify-content: center;
}

.hint { margin-top: 10rpx; color: #888; font-size: 24rpx; }