<view class="page">
  <view class="card">
    <textarea
      class="ta"
      placeholder="写下你的健康打卡/运动/饮食记录…"
      value="{{content}}"
      bindinput="onInput"
      maxlength="500"
      auto-height="true"
    />
    <view class="count">{{content.length}}/500</view>
  </view>

  <view class="card">
    <view class="row">
      <view class="label">图片（最多 6 张）</view>
      <button size="mini" bindtap="chooseImgs">选择</button>
    </view>

    <view class="imgs">
      <view wx:for="{{images}}" wx:key="path" class="img-wrap">
        <image class="img" src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="preview"/>
        <view class="del" data-idx="{{index}}" bindtap="removeImg">×</view>
      </view>
    </view>

    <view class="hint">发布后需要管理员审核通过才会出现在社区列表</view>
  </view>

  <button type="primary" bindtap="submit" disabled="{{submitting}}">
    {{submitting ? '发布中...' : '发布'}}
  </button>
</view>