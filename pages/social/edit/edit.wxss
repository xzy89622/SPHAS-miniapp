.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.7;
}

.ta {
  width: 100%;
  min-height: 180rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.count {
  text-align: right;
  color: #9ca3af;
  font-size: 24rpx;
  margin-top: 12rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.choose-btn {
  padding: 12rpx 22rpx;
  background: #111827;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.img-wrap {
  position: relative;
}

.img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.75);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}