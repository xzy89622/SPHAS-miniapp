<view class="page">
  <view class="card">
    <view class="title">修改后重新发布</view>
    <view class="sub">修改已驳回日志，提交后会重新进入审核流程</view>

    <textarea
      class="ta"
      placeholder="请输入日志内容"
      value="{{content}}"
      bindinput="onInput"
      maxlength="500"
      auto-height="true"
    />
    <view class="count">{{content.length}} / 500</view>
  </view>

  <view class="card">
    <view class="row">
      <view class="label">图片</view>
      <view class="choose-btn" bindtap="chooseImgs">添加图片</view>
    </view>

    <view class="imgs">
      <view wx:for="{{images}}" wx:key="index" class="img-wrap">
        <image
          class="img"
          src="{{item}}"
          mode="aspectFill"
          data-src="{{item}}"
          bindtap="preview"
        />
        <view class="del" data-idx="{{index}}" bindtap="removeImg">×</view>
      </view>
    </view>
  </view>

  <button type="primary" bindtap="submit" disabled="{{submitting}}">
    {{submitting ? '提交中...' : '保存并重新发布'}}
  </button>
</view>