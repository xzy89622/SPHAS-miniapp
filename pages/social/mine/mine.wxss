.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f7fb;
  box-sizing: border-box;
}

button::after {
  border: none;
}

.hero-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff, #f4f8ff);
  box-shadow: 0 10rpx 30rpx rgba(31, 75, 160, 0.08);
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.publish-btn {
  min-width: 190rpx;
  height: 76rpx;
  margin: 0;
  padding: 0 30rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #4f7cff, #6a8dff);
  border: none;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
  flex-shrink: 0;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-card {
  padding: 22rpx 12rpx;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.stats-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.stats-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.state-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #6b7280;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.state-card.err {
  color: #d14343;
  background: #fff5f5;
}

.post-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.05);
}

.post-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-tag.ok {
  color: #15803d;
  background: #eaf8ee;
}

.status-tag.pending {
  color: #b7791f;
  background: #fff7e6;
}

.status-tag.reject {
  color: #c53030;
  background: #fff1f1;
}

.status-tag.hidden {
  color: #6b7280;
  background: #f3f4f6;
}

.time-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.post-content {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
  word-break: break-all;
}

.cover-box {
  position: relative;
  width: 100%;
  height: 280rpx;
  margin-top: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.img-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.55);
  color: #ffffff;
  font-size: 22rpx;
}

.meta-row {
  display: flex;
  gap: 28rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-item {
  display: flex;
  align-items: center;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.ghost-btn,
.danger-btn {
  flex: 1;
  height: 76rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
}

.ghost-btn {
  color: #4f7cff;
  background: #eef4ff;
  border: 1rpx solid #d9e7ff;
}

.danger-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #ff6b6b, #ff8b8b);
  border: none;
}

.more {
  padding: 24rpx 0 36rpx;
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}