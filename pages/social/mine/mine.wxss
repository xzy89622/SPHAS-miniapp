.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fb 0%, #eef6f2 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  border-radius: 30rpx;
  padding: 30rpx 28rpx;
  color: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.16);
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.76);
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-stat {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.hero-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #4ade80;
}

.hero-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

.message-entry {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.tab {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #374151;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.04);
}

.tab-on {
  background: #111827;
  color: #ffffff;
}

.tab-on.wait {
  background: #f59e0b;
}

.tab-on.ok {
  background: #16a34a;
}

.tab-on.reject {
  background: #dc2626;
}

.tab-on.hide {
  background: #6b7280;
}

.state-card {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 44rpx 24rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.state-card.err {
  color: #ef4444;
}

.post-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-tag.ok {
  background: #ecfdf5;
  color: #16a34a;
}

.status-tag.wait {
  background: #fffbeb;
  color: #d97706;
}

.status-tag.reject {
  background: #fef2f2;
  color: #dc2626;
}

.status-tag.hide {
  background: #f3f4f6;
  color: #6b7280;
}

.time {
  font-size: 22rpx;
  color: #9ca3af;
}

.content {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: #111827;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.meta-row {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-item {
  display: flex;
  align-items: center;
}

.tip {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.wait-tip {
  background: #fff7ed;
  color: #d97706;
}

.reject-tip {
  background: #fef2f2;
  color: #dc2626;
}

.hide-tip {
  background: #f3f4f6;
  color: #6b7280;
}

.ok-tip {
  background: #ecfdf5;
  color: #16a34a;
}

.card-link {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 700;
}

.more {
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
  padding: 24rpx 0 40rpx;
}