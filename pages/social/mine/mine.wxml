<view class="page">
  <view class="hero-card">
    <view class="hero-left">
      <view class="hero-title">我的帖子</view>
      <view class="hero-sub">管理我发布的健康日志、查看审核状态和互动数据</view>
    </view>

    <button class="publish-btn" bindtap="goPublish">
      发新帖子
    </button>
  </view>

  <view class="stats-row">
    <view class="stats-card">
      <view class="stats-num">{{stats.total}}</view>
      <view class="stats-label">总数</view>
    </view>
    <view class="stats-card">
      <view class="stats-num">{{stats.pending}}</view>
      <view class="stats-label">待审核</view>
    </view>
    <view class="stats-card">
      <view class="stats-num">{{stats.passed}}</view>
      <view class="stats-label">已发布</view>
    </view>
    <view class="stats-card">
      <view class="stats-num">{{stats.rejected}}</view>
      <view class="stats-label">已驳回</view>
    </view>
  </view>

  <view wx:if="{{loading && list.length === 0}}" class="state-card">加载中...</view>
  <view wx:if="{{errMsg}}" class="state-card err">{{errMsg}}</view>
  <view wx:if="{{!loading && list.length === 0 && !errMsg}}" class="state-card">你还没有发布过帖子</view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="post-card">
      <view class="post-top">
        <view class="status-tag {{item.statusClass}}">
          {{item.statusText}}
        </view>

        <view class="time-text">{{item.createTimeText}}</view>
      </view>

      <view class="post-content" bindtap="goDetail" data-id="{{item.id}}">
        {{item.contentText}}
      </view>

      <view wx:if="{{item.firstImage}}" class="cover-box" bindtap="goDetail" data-id="{{item.id}}">
        <image class="cover-img" src="{{item.firstImage}}" mode="aspectFill"></image>
        <view wx:if="{{item.imageCount > 1}}" class="img-count">共 {{item.imageCount}} 张</view>
      </view>

      <view class="meta-row">
        <view class="meta-item">👍 {{item.likeCountText}}</view>
        <view class="meta-item">💬 {{item.commentCountText}}</view>
      </view>

      <view class="action-row">
        <button class="ghost-btn" bindtap="goDetail" data-id="{{item.id}}">
          查看
        </button>

        <button
          wx:if="{{item.canEdit}}"
          class="ghost-btn"
          bindtap="goEdit"
          data-id="{{item.id}}"
          data-can-edit="{{item.canEdit}}"
        >
          重新编辑
        </button>

        <button class="danger-btn" bindtap="onDelete" data-id="{{item.id}}">
          删除
        </button>
      </view>
    </view>
  </block>

  <view wx:if="{{hasMore && list.length > 0 && !loading}}" class="more" bindtap="loadMore">
    加载更多
  </view>
  <view wx:if="{{loading && list.length > 0}}" class="more">加载中...</view>
  <view wx:if="{{!hasMore && list.length > 0}}" class="more">没有更多了</view>
</view>