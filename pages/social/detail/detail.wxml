<view class="page">
  <view wx:if="{{loading && !detail}}" class="state-card">加载中...</view>

  <view wx:if="{{detail}}" class="detail-card">
    <view class="detail-head">
      <view class="user-box">
        <view class="avatar">{{detail.avatarText}}</view>
        <view class="user-meta">
          <view class="nickname">{{detail.nickname}}</view>
          <view class="time-text">{{detail.createTimeText}}</view>
        </view>
      </view>

      <view class="status-tag {{detail.statusClass}}">{{detail.statusText}}</view>
    </view>

    <view class="detail-content">{{detail.contentText}}</view>

    <view wx:if="{{detail.images.length > 0}}" class="image-grid">
      <block wx:for="{{detail.images}}" wx:key="index">
        <image
          class="grid-img"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{item}}"
        />
      </block>
    </view>

    <view class="meta-row">
      <view class="meta-item">👍 {{detail.likeCountText}}</view>
      <view class="meta-item">💬 {{detail.commentCountText}}</view>
    </view>

    <view class="action-row">
      <button class="ghost-btn" bindtap="onToggleLike" disabled="{{!canInteract}}">
        {{liked ? '取消点赞' : '点赞'}}
      </button>
    </view>
  </view>

  <view class="comment-card">
    <view class="section-title">评论区</view>

    <view wx:if="{{!canInteract && detail}}" class="tips-box">
      当前帖子还不能互动，只有已发布状态才可以评论和点赞。
    </view>

    <view class="comment-form">
      <textarea
        class="comment-textarea"
        placeholder="写点你的想法吧"
        maxlength="200"
        value="{{commentContent}}"
        bindinput="onCommentInput"
        disabled="{{!canInteract || saving}}"
      />
      <button class="primary-btn" bindtap="onSubmitComment" loading="{{saving}}" disabled="{{!canInteract || saving}}">
        发表评论
      </button>
    </view>

    <view wx:if="{{comments.length === 0}}" class="state-card mini">暂时还没有评论</view>

    <block wx:for="{{comments}}" wx:key="id">
      <view class="comment-item">
        <view class="comment-head">
          <view class="comment-user">
            <view class="avatar small">{{item.avatarText}}</view>
            <view class="nickname">{{item.nickname}}</view>
          </view>
          <view class="time-text">{{item.createTimeText}}</view>
        </view>

        <view class="comment-content">{{item.contentText}}</view>
      </view>
    </block>
  </view>
</view>