.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.status {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 32rpx 0;
}

.err {
  color: #e64340;
}

.content {
  font-size: 30rpx;
  color: #222;
  line-height: 1.8;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f2f2f2;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #888;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.time {
  flex-shrink: 0;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
}

.comment-box {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.ipt {
  flex: 1;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.c-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.c-item:last-child {
  border-bottom: none;
}

.c-content {
  font-size: 28rpx;
  color: #222;
  line-height: 1.7;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.c-time {
  font-size: 24rpx;
  color: #999;
}

.more {
  margin-top: 20rpx;
  text-align: center;
  color: #576b95;
  font-size: 26rpx;
  padding: 12rpx 0;
}