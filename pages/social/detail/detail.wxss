.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f7fb;
  box-sizing: border-box;
}

button::after {
  border: none;
}

.state-card {
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #6b7280;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.state-card.mini {
  margin-top: 20rpx;
  font-size: 24rpx;
}

.detail-card,
.comment-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.05);
}

.detail-head,
.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.user-box,
.comment-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7aa5ff, #5e86ff);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar.small {
  width: 58rpx;
  height: 58rpx;
  font-size: 24rpx;
}

.user-meta {
  min-width: 0;
}

.nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.time-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.status-tag.ok {
  color: #15803d;
  background: #eaf8ee;
}

.status-tag.pending {
  color: #b7791f;
  background: #fff7e6;
}

.status-tag.reject {
  color: #c53030;
  background: #fff1f1;
}

.status-tag.hidden {
  color: #6b7280;
  background: #f3f4f6;
}

.detail-content {
  margin-top: 22rpx;
  font-size: 30rpx;
  color: #374151;
  line-height: 1.9;
  word-break: break-all;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.grid-img {
  width: 100%;
  height: 210rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.meta-row {
  display: flex;
  gap: 28rpx;
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-item {
  display: flex;
  align-items: center;
}

.action-row {
  margin-top: 24rpx;
}

.ghost-btn,
.primary-btn {
  width: 100%;
  height: 78rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
}

.ghost-btn {
  color: #4f7cff;
  background: #eef4ff;
  border: 1rpx solid #d9e7ff;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #4f7cff, #6a8dff);
  border: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.tips-box {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #fff7e6;
  color: #b7791f;
  font-size: 24rpx;
  line-height: 1.7;
}

.comment-form {
  margin-top: 20rpx;
}

.comment-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 28rpx;
  color: #374151;
  box-sizing: border-box;
}

.comment-form .primary-btn {
  margin-top: 20rpx;
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-content {
  margin-top: 14rpx;
  padding-left: 74rpx;
  font-size: 27rpx;
  color: #374151;
  line-height: 1.8;
  word-break: break-all;
}