.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fb 0%, #eef6f2 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.state-wrap {
  margin-top: 30rpx;
}

.state-card {
  text-align: center;
  padding: 44rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #94a3b8;
  font-size: 28rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.state-card.err {
  color: #ef4444;
}

.post-card,
.comment-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 26rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.post-head {
  display: flex;
  align-items: center;
}

.avatar,
.comment-avatar {
  border-radius: 50%;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(34, 197, 94, 0.25);
  flex-shrink: 0;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  font-size: 34rpx;
  margin-right: 18rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
}

.nickname {
  max-width: 320rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  margin-left: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #16a34a;
  font-size: 20rpx;
  font-weight: 700;
}

.time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.status-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.status-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.status-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.7;
}

.status-link {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 700;
}

.post-content {
  margin-top: 20rpx;
  font-size: 29rpx;
  color: #334155;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-all;
}

.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.grid-img {
  width: 206rpx;
  height: 206rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
}

.post-footer {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  align-items: center;
}

.footer-item {
  display: flex;
  align-items: center;
  margin-right: 28rpx;
}

.footer-icon {
  font-size: 25rpx;
}

.footer-text {
  margin-left: 8rpx;
  font-size: 25rpx;
  color: #64748b;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.action-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.like-btn {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  color: #ffffff;
}

.mute-btn {
  background: #f1f5f9;
  color: #64748b;
}

.edit-btn {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #ffffff;
}

.del-btn {
  background: #fff1f2;
  color: #e11d48;
}

.comment-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.comment-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.comment-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.comment-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.ipt {
  flex: 1;
  height: 82rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #334155;
}

.send-btn {
  min-width: 110rpx;
  height: 82rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(34, 197, 94, 0.22);
}

.empty-tip {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  padding: 36rpx 0;
}

.comment-item {
  display: flex;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.comment-user {
  max-width: 260rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.comment-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}

.comment-content {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #334155;
  line-height: 1.8;
  word-break: break-all;
}

.more {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  padding-top: 20rpx;
}