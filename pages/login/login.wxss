page {
  height: 100%;
  color: #1f2937;
  background: linear-gradient(180deg, #f3f7ff 0%, #eefaf5 100%);
}

.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  padding: 120rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.bg {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
  opacity: 0.55;
}

.bg-1 {
  width: 420rpx;
  height: 420rpx;
  top: -120rpx;
  right: -100rpx;
  background: radial-gradient(circle, rgba(34, 197, 94, 0.20) 0%, rgba(34, 197, 94, 0) 72%);
}

.bg-2 {
  width: 360rpx;
  height: 360rpx;
  left: -120rpx;
  bottom: 120rpx;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.18) 0%, rgba(59, 130, 246, 0) 72%);
}

.login-wrapper {
  position: relative;
  z-index: 2;
}

.brand-box {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
  padding: 0 10rpx;
}

.brand-badge {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 36rpx rgba(34, 197, 94, 0.24);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.brand-text {
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: 46rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #111827;
}

.brand-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.login-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  padding: 40rpx 34rpx 36rpx;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.card-desc {
  margin-top: 10rpx;
  margin-bottom: 32rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 12rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: #374151;
}

.input-wrap {
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
  border-radius: 22rpx;
  padding: 0 24rpx;
}

.input {
  height: 92rpx;
  font-size: 30rpx;
  color: #111827;
  background: transparent;
}

.ph {
  color: #9ca3af;
}

.login-btn {
  margin-top: 12rpx;
  width: 100%;
  height: 92rpx;
  padding: 0;
  border: none;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  box-shadow: 0 18rpx 34rpx rgba(34, 197, 94, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 0.85;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.bottom-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.bottom-text {
  color: #6b7280;
}

.register-link {
  margin-left: 8rpx;
  color: #16a34a;
  font-weight: 600;
}