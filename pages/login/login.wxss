page {
  height: 100%;
  background: linear-gradient(180deg, #f5f8ff 0%, #eef8f2 100%);
  color: #1f2937;
}

.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  padding: 88rpx 36rpx 72rpx;
  box-sizing: border-box;
}

.bg {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
  filter: blur(12rpx);
}

.bg-1 {
  width: 420rpx;
  height: 420rpx;
  top: -120rpx;
  right: -120rpx;
  background: radial-gradient(circle, rgba(34, 197, 94, 0.18) 0%, rgba(34, 197, 94, 0) 72%);
}

.bg-2 {
  width: 340rpx;
  height: 340rpx;
  left: -120rpx;
  bottom: 80rpx;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0) 72%);
}

.login-wrapper {
  position: relative;
  z-index: 2;
}

.brand-box {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.brand-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
  box-shadow: 0 12rpx 28rpx rgba(34, 197, 94, 0.2);
}

.brand-text {
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #111827;
}

.brand-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.login-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 36rpx 30rpx 32rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.07);
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.card-desc {
  margin-top: 8rpx;
  margin-bottom: 28rpx;
  font-size: 25rpx;
  color: #6b7280;
  line-height: 1.6;
}

.form-item {
  margin-bottom: 22rpx;
}

.label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.input-wrap {
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  padding: 0 22rpx;
}

.input {
  height: 88rpx;
  font-size: 30rpx;
  color: #111827;
  background: transparent;
}

.ph {
  color: #9ca3af;
}

.login-btn,
.wechat-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
  border: none;
  padding: 0;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.login-btn::after,
.wechat-btn::after {
  border: none;
}

.login-btn {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(34, 197, 94, 0.22);
}

.wechat-btn {
  margin-top: 8rpx;
  background: #ffffff;
  color: #16a34a;
  border: 2rpx solid #ccefd7;
}

.login-btn[disabled],
.wechat-btn[disabled] {
  opacity: 0.8;
}

.split-text {
  text-align: center;
  margin: 24rpx 0 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.wx-tip {
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.7;
}

.bottom-row {
  margin-top: 30rpx;
  text-align: center;
  font-size: 25rpx;
}

.bottom-text {
  color: #6b7280;
}

.register-link {
  margin-left: 10rpx;
  color: #16a34a;
  font-weight: 700;
}