<view class="page">
  <view class="user-card">
    <view class="user-left">
      <view class="avatar">{{userAvatarText}}</view>
      <view class="user-main">
        <view class="user-name">{{userDisplayName}}</view>
        <view class="user-sub">
          <text>ID：{{userInfo.id || '-'}}</text>
          <text class="dot">·</text>
          <text>角色：{{userRoleText}}</text>
        </view>
      </view>
    </view>
    <button size="mini" class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <view class="profile-panel">
    <view class="panel-title">我的资料</view>

    <view class="info-row">
      <text class="info-label">登录状态</text>
      <text class="info-value">{{loginStatusText}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">昵称</text>
      <text class="info-value">{{userInfo.nickname || '未填写'}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">用户名</text>
      <text class="info-value">{{userInfo.username || '未填写'}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">手机号</text>
      <text class="info-value">{{userInfo.phone || '未绑定'}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">角色</text>
      <text class="info-value">{{userRoleText}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">用户 ID</text>
      <text class="info-value">{{userInfo.id || '-'}}</text>
    </view>
  </view>

  <view class="header">
    <view class="title">我的健康概览</view>
    <view class="sub">实时概览 + 最近趋势</view>
    <button class="btn" size="mini" bindtap="reload">刷新</button>
  </view>

  <view class="quick">
    <view class="q-title">快捷入口</view>
    <view class="q-row">
      <button size="mini" bindtap="goHealthRecord">健康记录</button>
      <button size="mini" bindtap="goAssessment">体质评估</button>
      <button size="mini" bindtap="goRecommend">今日推荐</button>
      <button size="mini" bindtap="goChallenge">健康挑战</button>
      <button size="mini" bindtap="goPoints">积分中心</button>
      <button size="mini" bindtap="goCommunity">健康社区</button>
      <button size="mini" bindtap="goMessages">消息中心</button>
    </view>
  </view>

  <view class="cards">
    <view class="card">
      <view class="label">累计健康记录</view>
      <view class="value">{{overview.totalRecords}}</view>
    </view>
    <view class="card">
      <view class="label">今日打卡</view>
      <view class="value">{{overview.todayRecords}}</view>
    </view>
    <view class="card">
      <view class="label">进行中挑战</view>
      <view class="value">{{overview.activeChallenges}}</view>
    </view>
    <view class="card">
      <view class="label">积分总计</view>
      <view class="value">{{overview.totalPoints}}</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">
      <text>最近 7 天趋势</text>
      <text class="hint">系统根据后端 trend 接口展示最近趋势数据</text>
    </view>

    <canvas class="chart" canvas-id="trendCanvas" id="trendCanvas" type="2d"></canvas>

    <view class="trend-list" wx:if="{{trendList.length > 0}}">
      <view class="trend-item" wx:for="{{trendList}}" wx:key="date">
        <text class="date">{{item.date}}</text>
        <text class="val">{{item.value}}</text>
      </view>
    </view>

    <view wx:if="{{trendList.length === 0 && !loading}}" class="empty">
      暂无趋势数据
    </view>
  </view>

  <view class="status" wx:if="{{loading}}">加载中...</view>
  <view class="status err" wx:if="{{!loading && errorMsg}}">{{errorMsg}}</view>
</view>