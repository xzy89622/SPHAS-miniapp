.page{
  min-height:100vh;
  padding:24rpx;
  box-sizing:border-box;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
}

.hero-card,
.section-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
}

.hero-card{
  padding:26rpx;
  margin-bottom:20rpx;
  background:linear-gradient(135deg,#ffffff 0%,#f7fbff 100%);
}

.hero-top{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:18rpx;
}

.hero-user{
  flex:1;
  min-width:0;
  display:flex;
  align-items:center;
  gap:18rpx;
}

.avatar{
  width:92rpx;
  height:92rpx;
  border-radius:50%;
  background:linear-gradient(135deg,#22c55e 0%,#16a34a 100%);
  color:#ffffff;
  font-size:38rpx;
  font-weight:700;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  box-shadow:0 10rpx 20rpx rgba(34,197,94,.18);
}

.hero-user-main{
  flex:1;
  min-width:0;
}

.hero-name-row{
  display:flex;
  align-items:center;
  gap:12rpx;
  flex-wrap:wrap;
}

.hero-name{
  font-size:38rpx;
  line-height:1.3;
  color:#1f2937;
  font-weight:700;
}

.role-badge{
  padding:6rpx 14rpx;
  border-radius:999rpx;
  background:#eef5ff;
  color:#2563eb;
  font-size:22rpx;
  line-height:1.2;
  font-weight:600;
}

.hero-sub{
  margin-top:8rpx;
  font-size:24rpx;
  color:#6b7280;
  line-height:1.5;
  display:flex;
  align-items:center;
  flex-wrap:wrap;
}

.hero-dot{
  margin:0 10rpx;
}

.logout-btn{
  flex-shrink:0;
  min-width:156rpx;
  height:72rpx;
  margin:0;
  padding:0 20rpx;
  border:none;
  border-radius:18rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#f8fafc;
  box-shadow:inset 0 0 0 1rpx #e5e7eb;
}

.logout-btn::after{
  border:none;
}

.logout-btn-text{
  font-size:28rpx;
  line-height:1;
  color:#334155;
  font-weight:600;
}

.hero-stats{
  display:flex;
  gap:16rpx;
  margin-top:24rpx;
}

.hero-stat{
  flex:1;
  min-width:0;
  padding:18rpx 16rpx;
  border-radius:22rpx;
  background:#f8fafc;
}

.hero-stat-label{
  font-size:22rpx;
  color:#94a3b8;
  line-height:1.4;
}

.hero-stat-value{
  margin-top:8rpx;
  font-size:34rpx;
  line-height:1.2;
  color:#1f2937;
  font-weight:700;
  word-break:break-all;
}

.section-card{
  padding:24rpx;
  margin-bottom:20rpx;
}

.section-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
  margin-bottom:18rpx;
}

.section-title{
  font-size:34rpx;
  line-height:1.4;
  color:#111827;
  font-weight:700;
}

.section-sub{
  margin-top:4rpx;
  font-size:24rpx;
  line-height:1.5;
  color:#94a3b8;
}

.info-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16rpx;
}

.info-item{
  padding:18rpx;
  border-radius:20rpx;
  background:#f8fafc;
  border:1rpx solid #edf2f7;
  box-sizing:border-box;
}

.info-label{
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
}

.info-value{
  margin-top:8rpx;
  font-size:28rpx;
  line-height:1.5;
  color:#334155;
  font-weight:600;
  word-break:break-all;
}

.refresh-btn{
  min-width:132rpx;
  height:72rpx;
  margin:0;
  padding:0 18rpx;
  border:none;
  border-radius:18rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 10rpx 20rpx rgba(37,99,235,.18);
}

.refresh-btn::after{
  border:none;
}

.refresh-btn-text{
  font-size:28rpx;
  line-height:1;
  color:#ffffff;
  font-weight:700;
}

.metric-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16rpx;
}

.metric-card{
  padding:20rpx;
  border-radius:22rpx;
  background:linear-gradient(180deg,#ffffff 0%,#f8fafc 100%);
  border:1rpx solid #edf2f7;
}

.metric-label{
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.4;
}

.metric-value{
  margin-top:10rpx;
  font-size:50rpx;
  line-height:1.15;
  color:#111827;
  font-weight:700;
}

.metric-tip{
  margin-top:10rpx;
  font-size:22rpx;
  color:#94a3b8;
  line-height:1.5;
}

.quick-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14rpx;
}

.quick-item{
  padding:18rpx 12rpx;
  border-radius:20rpx;
  background:#f8fafc;
  border:1rpx solid #edf2f7;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  min-height:124rpx;
  box-sizing:border-box;
}

.quick-item:active{
  opacity:.85;
}

.quick-icon{
  font-size:34rpx;
  line-height:1;
}

.quick-text{
  margin-top:10rpx;
  font-size:24rpx;
  line-height:1.4;
  color:#334155;
  font-weight:600;
  text-align:center;
}

.trend-head{
  align-items:flex-start;
}

.mini-badge{
  flex-shrink:0;
  padding:10rpx 16rpx;
  border-radius:999rpx;
  background:#eef5ff;
  color:#2563eb;
  font-size:22rpx;
  line-height:1.2;
  font-weight:700;
}

.chart{
  width:100%;
  height:340rpx;
  border-radius:22rpx;
  background:#fbfcfe;
}

.empty-card{
  margin-top:16rpx;
  padding:28rpx 20rpx;
  border-radius:22rpx;
  background:#f8fafc;
  text-align:center;
}

.empty-icon{
  font-size:42rpx;
  line-height:1;
}

.empty-text{
  margin-top:10rpx;
  font-size:26rpx;
  color:#94a3b8;
  line-height:1.5;
}

.trend-table{
  margin-top:18rpx;
  border-radius:20rpx;
  overflow:hidden;
  background:#f8fafc;
}

.trend-table-head,
.trend-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:18rpx 20rpx;
}

.trend-table-head{
  background:#f1f5f9;
}

.trend-head-date,
.trend-head-value{
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
  font-weight:600;
}

.trend-row{
  border-top:1rpx solid #eef2f7;
}

.trend-row:first-child{
  border-top:none;
}

.trend-date{
  font-size:28rpx;
  color:#334155;
  line-height:1.4;
}

.trend-value{
  font-size:30rpx;
  color:#111827;
  line-height:1.3;
  font-weight:700;
}

.status{
  margin-top:18rpx;
  padding:18rpx 20rpx;
  border-radius:20rpx;
  text-align:center;
  font-size:26rpx;
  line-height:1.5;
}

.loading-status{
  background:#ffffff;
  color:#64748b;
}

.error-status{
  background:#fff5f5;
  color:#dc2626;
}

.profile-card,
.overview-card,
.quick-card,
.trend-card{
  overflow:hidden;
}