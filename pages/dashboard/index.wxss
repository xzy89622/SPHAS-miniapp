.page {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: #f7f8fa;
}

.user-card,
.profile-panel,
.header,
.quick,
.card,
.panel {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.06);
}

.user-card {
  padding: 22rpx;
  margin-bottom: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.user-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #22c55e;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 6rpx;
}

.user-sub {
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.dot {
  margin: 0 10rpx;
}

.logout-btn {
  flex-shrink: 0;
}

.profile-panel {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f1f1f1;
  gap: 20rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #666;
  font-size: 26rpx;
}

.info-value {
  color: #222;
  font-size: 26rpx;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

.header {
  padding: 16rpx 16rpx 20rpx 16rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
}

.sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.btn {
  margin-top: 12rpx;
}

.quick {
  padding: 18rpx;
  margin-bottom: 18rpx;
}

.q-title {
  font-weight: 700;
  margin-bottom: 12rpx;
  font-size: 30rpx;
  color: #222;
}

.q-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.card {
  padding: 18rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
}

.value {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #222;
}

.panel {
  padding: 18rpx;
}

.hint {
  font-size: 22rpx;
  color: #888;
}

.chart {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background: #fafafa;
}

.trend-list {
  margin-top: 14rpx;
}

.trend-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.trend-item:last-child {
  border-bottom: none;
}

.date {
  color: #333;
  font-size: 26rpx;
}

.val {
  color: #111;
  font-size: 26rpx;
  font-weight: 600;
}

.status,
.empty {
  margin-top: 20rpx;
  text-align: center;
  color: #666;
  font-size: 26rpx;
}

.err {
  color: #d93025;
}