.page{
  min-height:100vh;
  padding:24rpx;
  box-sizing:border-box;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
}

.hero-card,
.content-card,
.meta-card,
.state-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
  margin-bottom:20rpx;
}

.hero-card{
  padding:28rpx;
  overflow:hidden;
  position:relative;
}

.hero-card.notice-risk{
  background:linear-gradient(135deg,#fff7f7 0%,#ffffff 100%);
  border-left:8rpx solid #ef4444;
}

.hero-card.notice-maintain{
  background:linear-gradient(135deg,#fffaf0 0%,#ffffff 100%);
  border-left:8rpx solid #f59e0b;
}

.hero-card.notice-normal{
  background:linear-gradient(135deg,#f7fbff 0%,#ffffff 100%);
  border-left:8rpx solid #3b82f6;
}

.hero-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
}

.notice-tag{
  flex-shrink:0;
  padding:8rpx 16rpx;
  border-radius:999rpx;
  font-size:22rpx;
  line-height:1.2;
  font-weight:700;
}

.notice-tag.tag-risk{
  background:#fef2f2;
  color:#dc2626;
}

.notice-tag.tag-maintain{
  background:#fffbeb;
  color:#d97706;
}

.notice-tag.tag-normal{
  background:#eff6ff;
  color:#2563eb;
}

.notice-time{
  flex-shrink:0;
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
}

.hero-title{
  margin-top:18rpx;
  font-size:44rpx;
  line-height:1.45;
  color:#111827;
  font-weight:700;
  word-break:break-all;
}

.hero-tip{
  margin-top:16rpx;
  padding:18rpx 20rpx;
  border-radius:20rpx;
  background:rgba(255,255,255,.72);
  font-size:25rpx;
  line-height:1.6;
  color:#64748b;
}

.content-card,
.meta-card{
  padding:24rpx;
}

.section-head{
  margin-bottom:18rpx;
}

.section-title{
  font-size:32rpx;
  line-height:1.4;
  color:#111827;
  font-weight:700;
}

.section-sub{
  margin-top:6rpx;
  font-size:24rpx;
  line-height:1.5;
  color:#94a3b8;
}

.content-text{
  font-size:30rpx;
  line-height:1.95;
  color:#334155;
  white-space:pre-wrap;
  word-break:break-all;
}

.meta-list{
  margin-top:14rpx;
  border-radius:20rpx;
  overflow:hidden;
  background:#f8fafc;
}

.meta-item{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:20rpx;
  padding:20rpx;
  border-top:1rpx solid #eef2f7;
}

.meta-item:first-child{
  border-top:none;
}

.meta-label{
  flex-shrink:0;
  font-size:25rpx;
  line-height:1.5;
  color:#94a3b8;
}

.meta-value{
  flex:1;
  text-align:right;
  font-size:27rpx;
  line-height:1.6;
  color:#334155;
  font-weight:600;
  word-break:break-all;
}

.state-card{
  text-align:center;
  padding:56rpx 32rpx;
}

.state-icon{
  font-size:56rpx;
  line-height:1;
}

.state-title{
  margin-top:18rpx;
  font-size:32rpx;
  line-height:1.4;
  font-weight:700;
  color:#1f2937;
}

.state-desc{
  margin-top:10rpx;
  font-size:25rpx;
  line-height:1.6;
  color:#94a3b8;
}

.retry-btn{
  width:100%;
  height:88rpx;
  margin-top:24rpx;
  padding:0;
  border:none;
  border-radius:22rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 12rpx 24rpx rgba(37,99,235,.20);
}

.retry-btn::after{
  border:none;
}

.retry-btn-text{
  font-size:30rpx;
  line-height:1;
  color:#ffffff;
  font-weight:700;
}