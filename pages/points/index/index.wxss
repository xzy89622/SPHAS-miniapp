.page {
  padding: 24rpx;
  background: #f7f8fa;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 14rpx;
}

.sub-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 16rpx;
}

.big {
  font-size: 72rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #22c55e;
  margin-bottom: 10rpx;
}

.tip,
.empty,
.badge-desc,
.r-remark,
.r-time,
.more-text {
  color: #999;
  font-size: 24rpx;
  line-height: 1.7;
}

.error {
  color: #e64340;
  font-size: 26rpx;
}

.badge-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.badge-item {
  background: #f6f7f7;
  border-radius: 16rpx;
  padding: 18rpx;
}

.badge-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 6rpx;
}

.rank-item,
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rank-item:last-child,
.record-item:last-child {
  border-bottom: none;
}

.rank-left {
  display: flex;
  align-items: center;
  min-width: 150rpx;
}

.rank-badge {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.rank-no {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
}

.rank-name {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.rank-score {
  min-width: 80rpx;
  text-align: right;
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}

.top1 {
  background: linear-gradient(90deg, #fff8db 0%, #ffffff 100%);
  border-radius: 14rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.top2 {
  background: linear-gradient(90deg, #f1f5f9 0%, #ffffff 100%);
  border-radius: 14rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.top3 {
  background: linear-gradient(90deg, #fff1e6 0%, #ffffff 100%);
  border-radius: 14rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.left {
  flex: 1;
  min-width: 0;
}

.right {
  flex-shrink: 0;
  text-align: right;
}

.r-type {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 6rpx;
}

.r-points {
  font-size: 34rpx;
  font-weight: 700;
  color: #22c55e;
  margin-bottom: 6rpx;
}

.more-wrap {
  padding-top: 20rpx;
  text-align: center;
}

.more-btn {
  background: #f3f4f6;
  color: #333;
  border-radius: 999rpx;
  padding: 0 24rpx;
}