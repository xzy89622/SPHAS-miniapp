<view class="page">
  <view class="card">
    <view class="title">体质评估问卷</view>
    <view class="tip">选完后点提交，生成你的体质结果</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载题目中...</view>

  <view wx:if="{{!loading}}">
    <block wx:for="{{questions}}" wx:key="id">
      <view class="q-card">
        <view class="q-title">{{index + 1}}. {{item.questionText}}</view>

        <!-- 数字题 -->
        <view wx:if="{{item.uiType === 'number'}}" class="input-wrap">
          <input
            type="number"
            placeholder="请输入数字"
            value="{{answers[item.id]}}"
            data-qid="{{item.id}}"
            bindinput="onInputAnswer"
          />
          <view class="input-tip">比如：3、5、8</view>
        </view>

        <!-- 文本题 -->
        <view wx:elif="{{item.uiType === 'text'}}" class="input-wrap">
          <textarea
            placeholder="请输入内容"
            value="{{answers[item.id]}}"
            data-qid="{{item.id}}"
            bindinput="onInputAnswer"
            auto-height="true"
          />
        </view>

        <!-- 是否题 -->
        <view wx:elif="{{item.uiType === 'boolean'}}" class="opt-list">
          <view
            class="opt-item {{answers[item.id] == 'yes' ? 'active' : ''}}"
            data-qid="{{item.id}}"
            data-value="yes"
            bindtap="onTapOption"
          >
            <view class="dot">{{answers[item.id] == 'yes' ? '✓' : ''}}</view>
            <text class="opt-text">是</text>
          </view>

          <view
            class="opt-item {{answers[item.id] == 'no' ? 'active' : ''}}"
            data-qid="{{item.id}}"
            data-value="no"
            bindtap="onTapOption"
          >
            <view class="dot">{{answers[item.id] == 'no' ? '✓' : ''}}</view>
            <text class="opt-text">否</text>
          </view>
        </view>

        <!-- 选择题 -->
        <view wx:else class="opt-list">
          <view
            wx:for="{{item.options}}"
            wx:for-item="opt"
            wx:key="value"
            class="opt-item {{answers[item.id] == opt.value ? 'active' : ''}}"
            data-qid="{{item.id}}"
            data-value="{{opt.value}}"
            bindtap="onTapOption"
          >
            <view class="dot">{{answers[item.id] == opt.value ? '✓' : ''}}</view>
            <text class="opt-text">{{opt.label}}</text>
          </view>

          <view wx:if="{{item.options.length === 0}}" class="empty-opt">
            这题没有选项，请联系管理员补充题库
          </view>
        </view>
      </view>
    </block>

    <button type="primary" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交评估'}}
    </button>
  </view>

  <!-- ✅ 结果展示：按你现在真实返回字段来 -->
  <view wx:if="{{result}}" class="card result">
    <view class="title">评估结果</view>

    <view class="line">BMI 等级：{{result.bmiLevel || '-'}}</view>
    <view class="line">推荐理由：{{result.reason || '-'}}</view>

    <!-- diet/sport 可能是对象 -->
    <view class="sub-title">饮食方案</view>
    <view class="line">{{(result.diet && (result.diet.name || result.diet.title || result.diet.description)) || '-'}}</view>

    <view class="sub-title">运动方案</view>
    <view class="line">{{(result.sport && (result.sport.name || result.sport.title || result.sport.description)) || '-'}}</view>

    <button bindtap="goRecommend">去看今日推荐</button>
  </view>
</view>