.page{
  min-height:100vh;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
  padding:24rpx;
  box-sizing:border-box;
}

.hero-card,
.content-card,
.meta-card,
.state-card{
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
  margin-bottom:20rpx;
}

.hero-card{
  padding:28rpx;
  background:linear-gradient(135deg,#ffffff 0%,#f7fbff 100%);
}

.hero-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
}

.article-tag{
  flex-shrink:0;
  padding:8rpx 16rpx;
  border-radius:999rpx;
  background:#eff6ff;
  color:#2563eb;
  font-size:22rpx;
  line-height:1.2;
  font-weight:700;
}

.article-time{
  flex-shrink:0;
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
}

.article-title{
  margin-top:18rpx;
  font-size:44rpx;
  font-weight:700;
  line-height:1.45;
  color:#111827;
  word-break:break-all;
}

.meta-row{
  display:flex;
  align-items:center;
  gap:14rpx;
  flex-wrap:wrap;
  margin-top:14rpx;
}

.meta-item{
  padding:8rpx 14rpx;
  border-radius:999rpx;
  background:#f8fafc;
  color:#64748b;
  font-size:23rpx;
  line-height:1.2;
}

.cover{
  width:100%;
  height:320rpx;
  border-radius:22rpx;
  margin-top:20rpx;
}

.summary-card{
  margin-top:18rpx;
  padding:20rpx;
  border-radius:22rpx;
  background:#f8fafc;
  border:1rpx solid #edf2f7;
}

.summary-title{
  font-size:24rpx;
  line-height:1.4;
  color:#94a3b8;
}

.summary-text{
  margin-top:8rpx;
  font-size:28rpx;
  line-height:1.7;
  color:#475569;
  word-break:break-all;
}

.content-card,
.meta-card{
  padding:24rpx;
}

.section-head{
  margin-bottom:18rpx;
}

.section-title{
  font-size:32rpx;
  line-height:1.4;
  color:#111827;
  font-weight:700;
}

.section-sub{
  margin-top:6rpx;
  font-size:24rpx;
  line-height:1.5;
  color:#94a3b8;
}

.article-content{
  font-size:30rpx;
  line-height:1.95;
  color:#334155;
  word-break:break-all;
}

.meta-list{
  margin-top:14rpx;
  border-radius:20rpx;
  overflow:hidden;
  background:#f8fafc;
}

.meta-line{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:20rpx;
  padding:20rpx;
  border-top:1rpx solid #eef2f7;
}

.meta-line:first-child{
  border-top:none;
}

.meta-label{
  flex-shrink:0;
  font-size:25rpx;
  line-height:1.5;
  color:#94a3b8;
}

.meta-value{
  flex:1;
  text-align:right;
  font-size:27rpx;
  line-height:1.6;
  color:#334155;
  font-weight:600;
  word-break:break-all;
}

.state-card{
  text-align:center;
  padding:56rpx 32rpx;
}

.state-icon{
  font-size:56rpx;
  line-height:1;
}

.state-title{
  margin-top:18rpx;
  font-size:32rpx;
  line-height:1.4;
  font-weight:700;
  color:#1f2937;
}

.state-desc{
  margin-top:10rpx;
  font-size:25rpx;
  line-height:1.6;
  color:#94a3b8;
}

.retry-btn{
  width:100%;
  height:88rpx;
  margin-top:24rpx;
  padding:0;
  border:none;
  border-radius:22rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  background:linear-gradient(135deg,#2563eb 0%,#3b82f6 100%);
  box-shadow:0 12rpx 24rpx rgba(37,99,235,.20);
}

.retry-btn::after{
  border:none;
}

.retry-btn-text{
  font-size:30rpx;
  line-height:1;
  color:#ffffff;
  font-weight:700;
}