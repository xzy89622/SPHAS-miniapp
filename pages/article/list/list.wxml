<view class="page">
  <view class="hero-card">
    <view class="hero-main">
      <view class="hero-title">健康科普</view>
      <view class="hero-desc">精选健康知识与生活方式建议，帮助你更好地管理日常健康</view>
    </view>

    <view class="hero-side">
      <view class="hero-side-num">{{list.length}}</view>
      <view class="hero-side-text">当前文章</view>
    </view>
  </view>

  <view class="top-bar">
    <view class="top-tip">下拉可刷新内容</view>
    <view class="top-count" wx:if="{{list.length > 0}}">共 {{list.length}} 篇</view>
  </view>

  <view wx:if="{{firstLoaded && !loading && list.length === 0}}" class="empty-card">
    <view class="empty-icon">📚</view>
    <view class="empty-title">暂无科普文章</view>
    <view class="empty-desc">当前还没有可展示的健康科普内容</view>
  </view>

  <view class="article-list" wx:if="{{list.length > 0}}">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="article-card"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="card-top">
        <view class="article-tag">{{item.uiTag}}</view>
        <view class="article-time">{{item.uiTime}}</view>
      </view>

      <view class="article-title">{{item.title}}</view>

      <view class="article-summary">{{item.uiSummary}}</view>

      <view class="card-bottom">
        <view class="article-meta">
          <text wx:if="{{item.views != null}}">阅读 {{item.views}}</text>
          <text wx:if="{{item.views != null && item.coverUrl}}" class="meta-dot">·</text>
          <text wx:if="{{item.coverUrl}}">含封面</text>
        </view>
        <view class="article-arrow">›</view>
      </view>
    </view>
  </view>

  <view class="footer-card" wx:if="{{list.length > 0}}">
    <view wx:if="{{loading}}" class="footer-text">加载中...</view>
    <view wx:else class="footer-text">已展示全部内容</view>
  </view>
</view>