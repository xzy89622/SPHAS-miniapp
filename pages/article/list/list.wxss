.page{
  min-height:100vh;
  background:linear-gradient(180deg,#f4f7fb 0%,#f7f8fc 100%);
  padding:24rpx;
  box-sizing:border-box;
}

.hero-card{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20rpx;
  padding:28rpx;
  border-radius:28rpx;
  background:linear-gradient(135deg,#ffffff 0%,#f7fbff 100%);
  box-shadow:0 10rpx 30rpx rgba(31,55,88,.06);
  margin-bottom:20rpx;
}

.hero-main{
  flex:1;
  min-width:0;
}

.hero-title{
  font-size:42rpx;
  line-height:1.3;
  font-weight:700;
  color:#1f2937;
}

.hero-desc{
  margin-top:10rpx;
  font-size:25rpx;
  line-height:1.6;
  color:#6b7280;
}

.hero-side{
  flex-shrink:0;
  min-width:148rpx;
  padding:18rpx 16rpx;
  border-radius:22rpx;
  background:#eef5ff;
  text-align:center;
}

.hero-side-num{
  font-size:38rpx;
  line-height:1.2;
  font-weight:700;
  color:#2563eb;
}

.hero-side-text{
  margin-top:6rpx;
  font-size:22rpx;
  line-height:1.4;
  color:#5b8def;
}

.top-bar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
  margin-bottom:18rpx;
}

.top-tip{
  flex:1;
  min-width:0;
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.5;
}

.top-count{
  flex-shrink:0;
  font-size:24rpx;
  color:#64748b;
  line-height:1.4;
}

.article-list{
  display:flex;
  flex-direction:column;
  gap:18rpx;
}

.article-card{
  background:#ffffff;
  border-radius:26rpx;
  padding:24rpx;
  box-shadow:0 10rpx 26rpx rgba(15,23,42,.05);
}

.card-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
}

.article-tag{
  flex-shrink:0;
  padding:8rpx 16rpx;
  border-radius:999rpx;
  background:#eff6ff;
  color:#2563eb;
  font-size:22rpx;
  line-height:1.2;
  font-weight:700;
}

.article-time{
  flex-shrink:0;
  font-size:23rpx;
  color:#94a3b8;
  line-height:1.4;
}

.article-title{
  margin-top:16rpx;
  font-size:38rpx;
  line-height:1.45;
  color:#111827;
  font-weight:700;
  word-break:break-all;
}

.article-summary{
  margin-top:12rpx;
  font-size:26rpx;
  line-height:1.7;
  color:#64748b;
}

.card-bottom{
  margin-top:18rpx;
  padding-top:18rpx;
  border-top:1rpx solid #f1f5f9;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16rpx;
}

.article-meta{
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.4;
  display:flex;
  align-items:center;
  flex-wrap:wrap;
}

.meta-dot{
  margin:0 10rpx;
}

.article-arrow{
  font-size:34rpx;
  line-height:1;
  color:#c0cad8;
}

.empty-card{
  margin-top:40rpx;
  padding:56rpx 32rpx;
  background:#ffffff;
  border-radius:28rpx;
  box-shadow:0 10rpx 28rpx rgba(15,23,42,.05);
  text-align:center;
}

.empty-icon{
  font-size:56rpx;
  line-height:1;
}

.empty-title{
  margin-top:20rpx;
  font-size:32rpx;
  line-height:1.4;
  color:#1f2937;
  font-weight:700;
}

.empty-desc{
  margin-top:10rpx;
  font-size:25rpx;
  line-height:1.6;
  color:#94a3b8;
}

.footer-card{
  margin-top:18rpx;
  padding:22rpx 20rpx 34rpx;
  text-align:center;
}

.footer-text{
  font-size:24rpx;
  color:#94a3b8;
  line-height:1.5;
}