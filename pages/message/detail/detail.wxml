<view class="page">
  <view wx:if="{{loading}}" class="state-card">加载中...</view>
  <view wx:if="{{errMsg}}" class="state-card err">{{errMsg}}</view>

  <block wx:if="{{!loading && detail}}">
    <view class="hero-card">
      <view class="type-row">
        <view class="type-tag {{detail.typeClass}}">
          <text class="type-icon">{{detail.typeIcon}}</text>
          <text>{{detail.typeText}}</text>
        </view>

        <view class="read-tag {{detail.isRead === 1 ? 'read' : 'unread'}}">
          {{detail.readText}}
        </view>
      </view>

      <view class="title">{{detail.titleText}}</view>
      <view class="sub">{{detail.subText}}</view>
    </view>

    <view class="card">
      <view class="section-title">消息信息</view>

      <view class="info-row">
        <view class="info-label">创建时间</view>
        <view class="info-value">{{detail.createTimeText}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">阅读状态</view>
        <view class="info-value">{{detail.readText}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">阅读时间</view>
        <view class="info-value">{{detail.readTimeText}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">消息类型</view>
        <view class="info-value">{{detail.typeText}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">消息来源</view>
        <view class="info-value">{{detail.sourceText}}</view>
      </view>

      <view class="info-row" wx:if="{{detail.canGoRisk}}">
        <view class="info-label">关联预警ID</view>
        <view class="info-value">{{detail.bizId}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-title">消息内容</view>
      <view class="content">{{detail.contentText}}</view>

      <button wx:if="{{detail.canGoRisk}}" class="go-btn" bindtap="goRiskRecord">
        查看对应风险记录
      </button>
    </view>
  </block>
</view>