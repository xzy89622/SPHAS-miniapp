<view class="page">
  <view class="hero">
    <view class="hero-left">
      <view class="hero-title">消息中心</view>
      <view class="hero-sub">查看风险预警、审核通知、勋章提醒和系统消息</view>
    </view>

    <view class="hero-right">
      <view class="hero-num">{{unreadCount}}</view>
      <view class="hero-label">未读</view>
    </view>
  </view>

  <view class="toolbar">
    <view class="filter-row">
      <view
        class="filter-chip {{currentFilter === 'all' ? 'filter-chip-active' : ''}}"
        bindtap="onFilterAll"
      >
        全部
      </view>

      <view
        class="filter-chip {{currentFilter === 'unread' ? 'filter-chip-active' : ''}}"
        bindtap="onFilterUnread"
      >
        未读
      </view>
    </view>

    <view class="action-btn" bindtap="readAll">全部设为已读</view>
  </view>

  <view wx:if="{{loading && list.length === 0}}" class="state-card">加载中...</view>
  <view wx:if="{{errMsg}}" class="state-card err">{{errMsg}}</view>
  <view wx:if="{{!loading && list.length === 0 && !errMsg}}" class="state-card">暂无消息</view>

  <block wx:for="{{list}}" wx:key="id">
    <view class="msg-card" bindtap="goDetail" data-id="{{item.id}}">
      <view class="msg-top">
        <view class="type-box {{item.typeClass}}">
          <view class="type-icon">{{item.typeIcon}}</view>
          <view class="type-text">{{item.typeText}}</view>
        </view>

        <view class="read-tag {{item.isRead === 1 ? 'read' : 'unread'}}">
          {{item.readText}}
        </view>
      </view>

      <view class="msg-title">{{item.titleText}}</view>
      <view class="msg-content">{{item.contentText}}</view>

      <view class="msg-bottom">
        <view class="msg-time">{{item.timeText}}</view>
        <view class="msg-link">查看详情</view>
      </view>
    </view>
  </block>

  <view wx:if="{{hasMore && list.length > 0 && !loading}}" class="more" bindtap="loadMore">
    加载更多
  </view>
  <view wx:if="{{loading && list.length > 0}}" class="more">加载中...</view>
  <view wx:if="{{!hasMore && list.length > 0}}" class="more">没有更多了</view>
</view>